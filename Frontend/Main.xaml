<Window x:Class="DocumentHub.FrontEnd.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DocumentHub.FrontEnd.Converters"
        Title="Document Hub"
        Background="#FFF3F4F6"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!--  Colors  -->
        <Color x:Key="SidebarColor">#FF1F2937</Color>
        <Color x:Key="AccentColor">#FF2563EB</Color>
        <SolidColorBrush x:Key="SidebarBrush"
                         Color="{StaticResource SidebarColor}" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="MenuItemHover"
                         Color="#FF111827" />
        <SolidColorBrush x:Key="TextBrush"
                         Color="#FFF9FAFB" />

        <!--  Icon font  -->
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

        <!--  Focus visual for keyboard users  -->
        <Style x:Key="ButtonFocusVisual"
               TargetType="Control">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle RadiusX="6"
                                   RadiusY="6"
                                   SnapsToDevicePixels="True"
                                   Stroke="#FF2563EB"
                                   StrokeThickness="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Menu button style  -->
        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="10,8" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Left" />
            <Setter Property="ToolTip"
                    Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}" />
            <Setter Property="FocusVisualStyle"
                    Value="{StaticResource ButtonFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Icon"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="16"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(Button.Tag)}" />
                                <TextBlock x:Name="Label"
                                           Grid.Column="1"
                                           Margin="10,0,6,0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource MenuItemHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Rounded button style  -->
        <Style x:Key="RoundedButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Circular ToggleButton style for BtnToggleSidebar (50% rounded)  -->
        <Style x:Key="CircularToggleButton"
               TargetType="ToggleButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Width"
                    Value="34" />
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <!--  CornerRadius set to half of Width/Height to achieve circular shape  -->
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="17"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource MenuItemHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Small caption style  -->
        <Style x:Key="CaptionStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#FF9CA3AF" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Margin"
                    Value="8,8,0,4" />
        </Style>

        <!--  Style for Advanced Management  -->
        <Style x:Key="SidebarExpanderStyle"
               TargetType="Expander">
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <!--  Header  -->
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{StaticResource ButtonFocusVisual}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border x:Name="HeaderBorder"
                                        Padding="10,8"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True"
                                        Width="182">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!--  Icon Arrow  -->
                                        <TextBlock x:Name="ExpanderIcon"
                                                   Grid.Column="0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="16"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   Text="&#xE70D;"
                                                   Margin="0,0,0,0" />
                                        <!--  Hide icon when click navbar  -->
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,6,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   Text="{TemplateBinding Header}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnToggleSidebar}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <!--  Sumary more  -->
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="20,4,0,0"
                                              Content="{TemplateBinding Content}"
                                              Visibility="Collapsed" />
                        </StackPanel>
                        <!--  Trigger change icon sumary more  -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded"
                                     Value="True">
                                <Setter TargetName="ExpandSite"
                                        Property="Visibility"
                                        Value="Visible" />
                                <Setter TargetName="ExpanderIcon"
                                        Property="Text"
                                        Value="&#xE70E;" />
                                <!--  Arrow top  -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton style Sidebar -->
        <Style x:Key="SidebarToggleButtonStyle"
               TargetType="ToggleButton">
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="10,8" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Left" />
            <Setter Property="FocusVisualStyle"
                    Value="{StaticResource ButtonFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- Icon -->
                                <TextBlock x:Name="Icon"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="16"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(ToggleButton.Tag)}" />
                                <!-- Label -->
                                <TextBlock x:Name="Label"
                                           Grid.Column="1"
                                           Margin="10,0,6,0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource MenuItemHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!--  Sidebar column uses Auto width; sidebar control animates its Width  -->
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar (make field explicit so code-behind can reference it)  -->
        <Border x:Name="Sidebar"
                Grid.Column="0"
                x:FieldModifier="public"
                Background="{StaticResource SidebarBrush}"
                CornerRadius="0"
                SnapsToDevicePixels="True">
            <!--  Sidebar style controls the width when collapsed  -->
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width"
                            Value="250" />
                    <Setter Property="Padding"
                            Value="14" />
                    <Style.Triggers>
                        <!--  match code-behind CollapsedWidth constant (64)  -->
                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnToggleSidebar}"
                                     Value="True">
                            <Setter Property="Width"
                                    Value="64" />
                            <Setter Property="Padding"
                                    Value="8" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel LastChildFill="True">
                <!--  Top: header with logo and collapse button  -->
                <Grid Margin="0,0,0,12"
                      DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <!--<Ellipse Width="40" Height="40" Fill="{StaticResource AccentBrush}" />-->

                        <StackPanel x:Name="BrandPanel"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnToggleSidebar}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       Text="Quản Lý Văn Bản" />
                        </StackPanel>
                    </StackPanel>

                    <!--
                        Collapse toggle (right side of header)
                        Wire Checked/Unchecked to the handlers in your code-behind so the
                        ToggleButton is the single source of truth for collapse state.
                    -->
                    <ToggleButton x:Name="BtnToggleSidebar"
                                  Grid.Column="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Checked="BtnToggleSidebar_Checked"
                                  IsChecked="False"
                                  Style="{StaticResource CircularToggleButton}"
                                  ToolTip="Collapse sidebar"
                                  Unchecked="BtnToggleSidebar_Unchecked">
                        <TextBlock FontFamily="{StaticResource IconFont}"
                                   FontSize="14"
                                   Text="&#xE700;" />
                    </ToggleButton>
                </Grid>

                <!--  Menu  -->
                <StackPanel>
                    <Button x:Name="btnDashboard"
                            Margin="0,6,0,0"
                            Click="BtnDashboard_Click"
                            Content="Bảng Điều Khiển"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE80F;" />
                    <Button x:Name="btnAnalytics"
                            Margin="0,6,0,0"
                            Click="BtnAnalytics_Click"
                            Content="Phân tích"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE9D2;" />
                    <Button x:Name="btnIncomingDoc"
                            Margin="0,6,0,0"
                            Click="btnIncomingDoc_Click"
                            Content="Văn Bản Đến"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE715;" />
                    <Button x:Name="btnOutgoingDoc"
                            Margin="0,6,0,0"
                            Click="btnOutgoing_Click"
                            Content="Văn Bản Đi"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE724;" />
                    <Button x:Name="btnProcess"
                            Margin="0,6,0,0"
                            Click="btnWorkProgress_Click"
                            Content="Tiến Độ Công Việc"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE94C;" />
                    <StackPanel>
                        <StackPanel Margin="0,6,0,0"
                                    Visibility="{Binding IsChecked, ElementName=BtnToggleSidebar, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <ToggleButton x:Name="btnAdvanced"
                                          Style="{StaticResource SidebarToggleButtonStyle}"
                                          IsChecked="True"
                                          Tag="&#xE70D;"
                                          Content="Quản lý nâng cao" />

                            <!-- Child Content -->
                            <StackPanel Margin="20,0,0,0"
                                        Visibility="{Binding IsChecked, ElementName=btnAdvanced, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button Margin="0,4,0,0"
                                        Click="btnReceivingOfficer_Click"
                                        Content="Cán bộ tiếp nhận"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Tag="&#xE779;" />
                                <Button Margin="0,4,0,0"
                                        Click="btnConstructionStaff_Click"
                                        Content="Cán bộ xử lý"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Tag="&#xE8D4;" />
                                <Button Margin="0,4,0,0"
                                        Click="btnSigner_Click"
                                        Content="Người ký"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Tag="&#xE70F;" />
                                <Button Margin="0,4,0,0"
                                        Click="btnRecpient_Click"
                                        Content="Nơi nhận"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Tag="&#xE707;" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="btnAbout"
                            Margin="0,6,0,0"
                            Click="btnAbout_Click"
                            Content="Về Chúng Tôi"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE902;" />
                    <Button x:Name="btnExit"
                            Margin="0,6,0,0"
                            Click="btnExit_Click"
                            Content="Thoát"
                            Style="{StaticResource SidebarButtonStyle}"
                            Tag="&#xE7E8;" />
                </StackPanel>

                <!--  Footer area (docked bottom)  -->
                <StackPanel Margin="0,30,0,0"
                            VerticalAlignment="Bottom"
                            DockPanel.Dock="Bottom"
                            Orientation="Horizontal">
                    <TextBlock Margin="0,0,50,0"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3AF"
                               Text="v1.0.0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  Content area  -->
        <Grid Grid.Column="1"
              Margin="18,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Main content card  -->
            <Border Grid.Row="1"
                    Padding="18"
                    Background="White"
                    CornerRadius="12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect"
                                Value="{x:Null}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static SystemParameters.DropShadow}}"
                                         Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12"
                                                          ShadowDepth="2"
                                                          Color="#40000000" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <ContentControl x:Name="ContentArea" />
            </Border>
        </Grid>
    </Grid>
</Window>
