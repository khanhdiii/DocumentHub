<Window x:Class="DocumentHub.FrontEnd.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Document Hub" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F4F6">
    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="SidebarColor">#FF1F2937</Color>
        <Color x:Key="AccentColor">#FF2563EB</Color>
        <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="MenuItemHover" Color="#FF111827" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFF9FAFB" />

        <!-- Icon font -->
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

        <!-- Focus visual for keyboard users -->
        <Style x:Key="ButtonFocusVisual" TargetType="Control">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Stroke="#FF2563EB" StrokeThickness="2" RadiusX="6" RadiusY="6" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu button style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10 8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource ButtonFocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Icon" FontFamily="{StaticResource IconFont}" FontSize="16"
                                           Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(Button.Tag)}"
                                           HorizontalAlignment="Left"/>
                                <TextBlock x:Name="Label" Grid.Column="1" Text="{TemplateBinding Content}"
                                           FontSize="14" VerticalAlignment="Center" Margin="10,0,6,0"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded button style -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Circular ToggleButton style for BtnToggleSidebar (50% rounded) -->
        <Style x:Key="CircularToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- CornerRadius set to half of Width/Height to achieve circular shape -->
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="17" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small caption style -->
        <Style TargetType="TextBlock" x:Key="CaptionStyle">
            <Setter Property="Foreground" Value="#FF9CA3AF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="8,8,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar column uses Auto width; sidebar control animates its Width -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar (make field explicit so code-behind can reference it) -->
        <Border x:Name="Sidebar"
                x:FieldModifier="public"
                Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                CornerRadius="0"
                SnapsToDevicePixels="True">
            <!-- Sidebar style controls the width when collapsed -->
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="250"/>
                    <Setter Property="Padding" Value="14"/>
                    <Style.Triggers>
                        <!-- match code-behind CollapsedWidth constant (64) -->
                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnToggleSidebar}" Value="True">
                            <Setter Property="Width" Value="64"/>
                            <Setter Property="Padding" Value="8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel LastChildFill="True">
                <!-- Top: header with logo and collapse button -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="40" Height="40" Fill="{StaticResource AccentBrush}" />

                            <StackPanel x:Name="BrandPanel" Margin="10,0,0,0" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnToggleSidebar}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="DocumentHub" FontWeight="Bold" Foreground="{StaticResource TextBrush}" FontSize="16"/>
                            <TextBlock Text="Manage your documents" FontSize="11" Foreground="#FF9CA3AF"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Collapse toggle (right side of header)
                         Wire Checked/Unchecked to the handlers in your code-behind so the
                         ToggleButton is the single source of truth for collapse state. -->
                    <ToggleButton x:Name="BtnToggleSidebar"
                                  Grid.Column="1"
                                  Style="{StaticResource CircularToggleButton}"
                                  ToolTip="Collapse sidebar"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  IsChecked="False"
                                  Checked="BtnToggleSidebar_Checked"
                                  Unchecked="BtnToggleSidebar_Unchecked">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE700;" FontSize="14" />
                    </ToggleButton>
                </Grid>

                <!-- Menu -->
                <StackPanel>
                    <Button x:Name="btnDashboard" Style="{StaticResource SidebarButtonStyle}" Tag="&#xE80F;" Content="Dashboard" Click="BtnDashboard_Click" Margin="0,6,0,0"/>
                    <Button x:Name="btnIncomingDoc" Style="{StaticResource SidebarButtonStyle}" Tag="&#xE8A5;" Content="Incoming Doc" Click="btnIncomingDoc_Click" Margin="0,6,0,0"/>

                    <!-- spacer -->
                    <StackPanel Height="8"/>

                    <Button x:Name="btnAbout" Style="{StaticResource SidebarButtonStyle}" Tag="&#xE77B;" Content="About" Click="btnAbout_Click" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Footer area (docked bottom) -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,10,0,0">
                    <TextBlock Text="v1.0.0" Foreground="#FF9CA3AF" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1" Margin="18,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" Height="48" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Welcome to DocumentHub" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#FF111827"/>

                <Border Grid.Column="1" Background="#FFF6F7FB" CornerRadius="8" Padding="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Watermark implementation for WPF TextBox (PlaceholderText is invalid in WPF) -->
                        <Grid Width="160" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="#FF374151" Padding="6,0,26,0"/>
                            <TextBlock Text="Search..." Foreground="#FF9CA3AF" Margin="6,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Clear button shown when there's text -->
                            <Button x:Name="BtnClearSearch" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Clear search" FontSize="12" Padding="0"
                                    Background="Transparent" BorderThickness="0" Visibility="Collapsed" Click="BtnClearSearch_Click">
                                <TextBlock Text="✕" Foreground="#FF6B7280"/>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <!-- Hide when text is empty or null; visible otherwise -->
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Use the RoundedButtonStyle instead of CornerRadius attribute -->
                        <Button Width="36" Height="28" Style="{StaticResource RoundedButtonStyle}" ToolTip="Open search">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE11A;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main content card -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="18">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Effect" Value="{x:Null}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Source={x:Static SystemParameters.DropShadow}}" Value="True">
                      <Setter Property="Effect">
                        <Setter.Value>
                          <DropShadowEffect Color="#40000000" BlurRadius="12" ShadowDepth="2"/>
                        </Setter.Value>
                      </Setter>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>

              <ContentControl x:Name="ContentArea"/>
            </Border>
        </Grid>
    </Grid>
</Window>