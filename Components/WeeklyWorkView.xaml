<UserControl x:Class="DocumentHub.Components.WeeklyWorkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="White"
          CornerRadius="12"
          Padding="20"
          BorderBrush="#2B6BEA"
          BorderThickness="2"
          MaxWidth="400"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Header với nút Close -->
      <DockPanel Grid.Row="0">
        <TextBlock Text="📅 Công việc trong tuần"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2B6BEA"
                   DockPanel.Dock="Left"
                   VerticalAlignment="Center" />
        <Button Content="✖"
                Width="28"
                Height="28"
                DockPanel.Dock="Right"
                Background="Transparent"
                Foreground="Red"
                BorderThickness="0"
                Cursor="Hand"
                Click="CloseButton_Click" />
      </DockPanel>

      <!--List job -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    MaxWidth="400">
        <ItemsControl Grid.Row="1"
                    ItemsSource="{Binding WeeklyWorkList}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1"
                    Padding="6">
              <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding Name}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#2B6BEA" />

                <StackPanel Orientation="Horizontal"
                            Margin="0,4,0,0">
                  <TextBlock Text="📅 Ngày bắt đầu: "
                             FontWeight="SemiBold"
                             Foreground="#555" />
                  <TextBlock Text="{Binding StartDate, StringFormat='dd/MM/yyyy'}"
                             Foreground="#333" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Margin="0,2,0,0">
                  <TextBlock Text="📊 Tiến độ: "
                             FontWeight="SemiBold"
                             Foreground="#555" />
                  <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}"
                             Foreground="#333" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Margin="0,2,0,0">
                  <TextBlock Text="📌 Trạng thái: "
                             FontWeight="SemiBold"
                             Foreground="#555" />
                  <TextBlock Text="{Binding Status}"
                             Foreground="#333" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Grid>
  </Border>
</UserControl>
