<UserControl x:Class="DocumentHub.Components.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto"
             Width="Auto">
  <Border x:Name="NotificationPanel"
          Background="Gray"
          CornerRadius="8"
          Padding="15,30"
          Margin="10"
          Visibility="Collapsed"
          HorizontalAlignment="Right"
          VerticalAlignment="Top">

  <!-- Container-->
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="4" />
      <!-- Progress bar -->
    </Grid.RowDefinitions>

    <!-- Content Notification -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="30" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="30" />
      </Grid.ColumnDefinitions>

      <!-- Icon -->
      <TextBlock x:Name="NotificationIcon"
                 FontSize="18"
                 Foreground="White"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center"
                 Grid.Column="0"
                 Text="ℹ️" />

      <!-- Message -->
      <TextBlock x:Name="NotificationText"
                 FontSize="14"
                 FontWeight="Bold"
                 Foreground="White"
                 VerticalAlignment="Center"
                 TextWrapping="NoWrap"
                 TextTrimming="CharacterEllipsis"
                 Grid.Column="1"
                 MinWidth="120"
                 Text="Thông báo" />

      <!-- Close Button -->
      <Button x:Name="CloseButton"
              Content="✖"
              FontSize="12"
              Width="20"
              Height="20"
              Background="Transparent"
              Foreground="White"
              BorderThickness="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Grid.Column="2"
              Click="CloseButton_Click" />
    </Grid>

    <!-- Progress bar -->
    <ProgressBar x:Name="NotificationProgress"
                 Grid.Row="1"
                 Foreground="White"
                 Background="#66000000"
                 Maximum="100"
                 Value="100"
                 VerticalAlignment="Bottom" />
  </Grid>
  </Border>
</UserControl>
