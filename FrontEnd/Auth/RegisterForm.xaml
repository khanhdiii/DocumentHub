<Window x:Class="DocumentHub.FrontEnd.Auth.RegisterForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký PIN"
        Height="500"
        Width="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Style cho PasswordBox -->
        <Style x:Key="RoundedPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D4A017"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="PasswordChar" Value="•"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Button -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- BACKGROUND -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2F5A3A" Offset="0.3"/>
            <GradientStop Color="#4F8A54" Offset="0.5"/>
            <GradientStop Color="#ffffff" Offset="0.7"/>
            <GradientStop Color="#7BBF7B" Offset="0.8"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <!-- Background image -->
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Image/backgroundred.jpg"
                        Stretch="UniformToFill"
                        Opacity="0.65"/>
        </Grid.Background>

        <!-- Notification -->
        <StackPanel x:Name="NotificationContainer"
                    Orientation="Vertical"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10"
                    Panel.ZIndex="999"/>

        <!-- Khung chính -->
        <Border Opacity="0.7"
                Width="400"
                Height="400"
                BorderBrush="#FFD966"
                Background="#F7E7C3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="15"
                BorderThickness="2">

            <StackPanel Orientation="Vertical">
                <!-- Title -->
                <Label Content="ĐĂNG KÝ MÃ PIN"
                       Foreground="#FFE20B0B"
                       FontFamily="Montserrat"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,25"/>

                <!-- Nhập PIN -->
                <StackPanel Margin="0,10">
                    <TextBlock FontSize="16" Text="Nhập PIN (6 số)" FontWeight="Bold"/>
                    <PasswordBox x:Name="tb_Pin"
                                 MaxLength="6"
                                 FontSize="20"
                                 Width="200"
                                 HorizontalAlignment="Center"
                                 Style="{StaticResource RoundedPasswordBoxStyle}"/>
                </StackPanel>

                <!-- Xác nhận PIN -->
                <StackPanel Margin="0,10">
                    <TextBlock FontSize="16" Text="Xác nhận PIN" FontWeight="Bold"/>
                    <PasswordBox x:Name="tb_ConfirmPin"
                                 MaxLength="6"
                                 FontSize="20"
                                 Width="200"
                                 HorizontalAlignment="Center"
                                 Style="{StaticResource RoundedPasswordBoxStyle}"/>
                </StackPanel>

                <!-- Message -->
                <TextBlock x:Name="tb_Message"
                           Text=""
                           FontFamily="Montserrat"
                           Foreground="#FFE20B0B"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,10,0,10"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <Button x:Name="btn_ChangePIN"
                            Content="Đăng ký mã PIN"
                            FontFamily="Montserrat"
                            Width="150"
                            Height="45"
                            Background="#D4A017"
                            Foreground="White"
                            BorderBrush="#A08013"
                            BorderThickness="2"
                            Click="btn_RegisterPIN_Click"/>

                    <Button x:Name="btn_Back"
                            Content="Trở lại"
                            Width="150"
                            Height="45"
                            FontFamily="Montserrat"
                            Background="#FF222020"
                            Foreground="White"
                            BorderBrush="#A08013"
                            BorderThickness="2"
                            Click="btn_Back_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Label Content="© Văn bằng 2 - K02 TTHL, BDNV &amp; GDNN  số 2 2025-2026"
               HorizontalAlignment="Left"
               Margin="416,492,0,0"
               VerticalAlignment="Top"
               FontFamily="Montserrat"
               FontWeight="Bold"
               Foreground="Black"/>
    </Grid>
</Window>
