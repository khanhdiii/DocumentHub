<Window x:Class="DocumentHub.FrontEnd.Auth.CreateForgotPIN"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:DocumentHub.FrontEnd"
        mc:Ignorable="d"
        Title="QUÊN MÃ PIN"
        Height="720"
        Width="800"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <!-- Style for PasswordBox -->
    <Style x:Key="RoundedPasswordBoxStyle"
           TargetType="PasswordBox">
      <Setter Property="Background"
              Value="White" />
      <Setter Property="BorderBrush"
              Value="#D4A017" />
      <Setter Property="BorderThickness"
              Value="2" />
      <Setter Property="Foreground"
              Value="Black" />
      <Setter Property="PasswordChar"
              Value="•" />
      <Setter Property="Padding"
              Value="10,0,0,0" />
      <Setter Property="Height"
              Value="35" />

      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="PasswordBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Style for Textbox -->
    <Style x:Key="RoundedTextBoxStyle"
           TargetType="TextBox">
      <Setter Property="Background"
              Value="White" />
      <Setter Property="BorderBrush"
              Value="#D4A017" />
      <Setter Property="BorderThickness"
              Value="2" />
      <Setter Property="Foreground"
              Value="Black" />
      <Setter Property="Padding"
              Value="10,0,0,0" />
      <Setter Property="Height"
              Value="35" />
      <Setter Property="VerticalContentAlignment"
              Value="Center" />

      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="12">
              <ScrollViewer x:Name="PART_ContentHost" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Style for button -->
    <Style TargetType="Button">
      <Setter Property="Margin"
              Value="10" />
      <Setter Property="FontWeight"
              Value="Bold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="15">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <!-- Hover Button hand-->
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Cursor"
                        Value="Hand" />
              </Trigger>

            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Style for ComboBox and TextBox for consistent appearance -->
    <Style TargetType="ComboBox">
      <Setter Property="Height"
              Value="35" />
      <Setter Property="BorderBrush"
              Value="#D4A017" />
      <Setter Property="BorderThickness"
              Value="2" />
      <Setter Property="Margin"
              Value="0,5,0,5" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Height"
              Value="35" />
      <Setter Property="Padding"
              Value="10 0" />
      <Setter Property="Margin"
              Value="0,5,0,5" />
      <Setter Property="BorderBrush"
              Value="#D4A017" />
      <Setter Property="BorderThickness"
              Value="2" />
      <Setter Property="VerticalContentAlignment"
              Value="Center" />
      <Setter Property="FontFamily"
              Value="Montserrat" />
    </Style>
  </Window.Resources>

  <!-- BACKGROUND  -->
  <Window.Background>
    <LinearGradientBrush StartPoint="0,0"
                         EndPoint="1,1">
      <GradientStop Color="#2F5A3A"
                    Offset="0.3" />
      <GradientStop Color="#4F8A54"
                    Offset="0.5" />
      <GradientStop Color="#ffffff"
                    Offset="0.7" />
      <GradientStop Color="#7BBF7B"
                    Offset="0.8" />
    </LinearGradientBrush>
  </Window.Background>

  <Grid>
    <!-- URL image -->
    <Grid.Background>
      <ImageBrush ImageSource="/Assets/Image/backgroundred.jpg"
                  Stretch="UniformToFill"
                  Opacity="0.65" />
    </Grid.Background>

    <!-- Second border  -->
    <Border Opacity="0.8"
            Width="600"
            Height="620"
            BorderBrush="#FFD966"
            Background="#F7E7C3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="15"
            BorderThickness="3">

      <StackPanel Orientation="Vertical"
                  Margin="40,20,40,20">
        <!-- Title CREATE FORGOT PIN -->
        <Label Content="TẠO MÃ PIN CẤP 2"
               FontFamily="Montserrat"
               Foreground="#FFE20B0B"
               FontSize="28"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="0,5,0,10" />

        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Question 1 -->
          <StackPanel Grid.Row="0">
            <TextBlock FontWeight="SemiBold"
                       FontFamily="Montserrat"
                       Margin="5,0,0,0">
                            <Run Text="Câu hỏi 1 " />
                            <Run Text="(*)"
                                 Foreground="Red" />
                            <Run Text=":" />
            </TextBlock>
            <ComboBox Name="cbQuestion1" />
            <TextBox Name="tbAnswer1" />
            <!-- Message/Error Block -->
            <TextBlock x:Name="tb_MessageQuestion1"
                       Text=""
                       Foreground="#FFE20B0B"
                       FontWeight="Bold"
                       FontSize="12"
                       Margin="0,5,0,5" />

          </StackPanel>

          <!-- Question 2 -->
          <StackPanel Grid.Row="1"
                      Margin="0,5">
            <TextBlock FontWeight="SemiBold"
                       FontFamily="Montserrat"
                       Margin="5,0,0,0">
                            <Run Text="Câu hỏi 2 " />
                            <Run Text="(*)"
                                 Foreground="Red" />
                            <Run Text=":" />
            </TextBlock>
            <ComboBox Name="cbQuestion2" />
            <TextBox Name="tbAnswer2" />
            <TextBlock x:Name="tb_MessageQuestion2"
                       Text=""
                       Foreground="#FFE20B0B"
                       FontWeight="Bold"
                       FontSize="12"
                       Margin="0,5,0,9" />
          </StackPanel>

          <!-- Create password 2 (New Password) -->
          <StackPanel Grid.Row="2"
                      Margin="0,15,0,5">
            <TextBlock FontWeight="SemiBold"
                       FontFamily="Montserrat"
                       Margin="5,0,0,0">
                            <Run Text="Tạo mật khẩu  " />
                            <Run Text="(*)"
                                 Foreground="Red" />
                            <Run Text=":" />
            </TextBlock>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*" />
                <ColumnDefinition Width="197*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
              </Grid.ColumnDefinitions>

              <!-- PasswordBox  -->
              <PasswordBox x:Name="pbNewPassword"
                           Style="{StaticResource RoundedPasswordBoxStyle}"
                           Visibility="Visible"
                           Grid.ColumnSpan="2"
                           Margin="0,2,0,2" />

              <!-- TextBox Show new password -->
              <TextBox x:Name="tbNewPassword"
                       Style="{StaticResource RoundedTextBoxStyle}"
                       Visibility="Collapsed"
                       Grid.ColumnSpan="2"
                       Margin="0,2,0,2" />

              <!-- Toggle Eye -->
              <Button Grid.Column="2"
                      Click="ToggleNewPassword_Click"
                      BorderThickness="0"
                      Margin="10,10,10,10">
                <fa:FontAwesome Icon="Eye"
                                Foreground="#D4A017"
                                FontSize="18" />
              </Button>

              <!-- Info -->
              <Button Grid.Column="3"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="0"
                      Margin="10,10,10,10">
                <fa:FontAwesome Icon="InfoCircle"
                                Foreground="#D4A017"
                                FontSize="18" />

                <Button.ToolTip>
                  <ToolTip Style="{x:Null}">
                    <StackPanel>
                      <TextBlock FontWeight="Bold"
                                 Margin="0,0,0,5">Quy định mật khẩu:</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Không dùng tiếng Việt</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Không dấu</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Ít nhất 6 ký tự</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Nên có chữ &amp; số</TextBlock>
                    </StackPanel>
                  </ToolTip>
                </Button.ToolTip>
              </Button>
            </Grid>

            <TextBlock x:Name="tb_MessagePassword"
                       Foreground="#FFE20B0B"
                       FontWeight="Bold"
                       FontSize="12" />
          </StackPanel>

          <!-- Confirm password 2  -->
          <StackPanel Grid.Row="3"
                      Margin="0,5,0,15">
            <TextBlock FontWeight="SemiBold"
                       FontFamily="Montserrat"
                       Margin="5,0,0,0">
                            <Run Text="Xác nhận mật khẩu 2 " />
                            <Run Text="(*)"
                                 Foreground="Red" />
                            <Run Text=":" />
            </TextBlock>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="47*" />
                <ColumnDefinition Width="170*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
              </Grid.ColumnDefinitions>

              <!-- PasswordBox -->
              <PasswordBox x:Name="pbConfirmPassword"
                           Style="{StaticResource RoundedPasswordBoxStyle}"
                           Visibility="Visible"
                           Grid.ColumnSpan="2"
                           Margin="0,2,0,2" />

              <!-- TextBox Show -->
              <TextBox x:Name="tbConfirmPassword"
                       Style="{StaticResource RoundedTextBoxStyle}"
                       Visibility="Collapsed"
                       Grid.ColumnSpan="2"
                       Margin="0,2,0,2" />

              <!-- Toggle Eye -->
              <Button Grid.Column="2"
                      Click="ToggleConfirmPassword_Click"
                      BorderThickness="0"
                      Margin="10,10,10,10">
                <fa:FontAwesome Icon="Eye"
                                Foreground="#D4A017"
                                FontSize="18" />
              </Button>
              <!-- Info -->
              <Button Grid.Column="3"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="0"
                      Margin="10,10,10,10">
                <fa:FontAwesome Icon="InfoCircle"
                                Foreground="#D4A017"
                                FontSize="18" />

                <Button.ToolTip>
                  <ToolTip Style="{x:Null}">
                    <StackPanel>
                      <TextBlock FontWeight="Bold"
                                 Margin="0,0,0,5">Quy định mật khẩu:</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Không dùng tiếng Việt</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Không dấu</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Ít nhất 6 ký tự</TextBlock>
                      <TextBlock  Foreground="#D4A017">• Nên có chữ &amp; số</TextBlock>
                    </StackPanel>
                  </ToolTip>
                </Button.ToolTip>
              </Button>
            </Grid>

            <TextBlock x:Name="tb_MessageConfirmPassword"
                       Foreground="#FFE20B0B"
                       FontWeight="Bold"
                       FontSize="12" />
          </StackPanel>

          <!-- Button Confirm-->
          <Button Grid.Row="5"
                  Content="Xác nhận"
                  HorizontalAlignment="Center"
                  Width="180"
                  Height="40"
                  FontSize="16"
                  Background="#D4A017"
                  BorderBrush="#A08013"
                  BorderThickness="2"
                  Foreground="#000000"
                  Click="Submit_Click"
                  VerticalAlignment="Center" />
        </Grid>

      </StackPanel>

    </Border>
    <Label Content="© K02 - 2025"
           HorizontalAlignment="Right"
           VerticalAlignment="Bottom"
           Margin="0,0,50,0" />

  </Grid>
</Window>
