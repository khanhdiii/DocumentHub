<Window x:Class="DocumentHub.FrontEnd.Auth.LoginForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentHub.FrontEnd"
        xmlns:components="clr-namespace:DocumentHub.Components"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="ĐĂNG NHẬP"
        Height="450"
        Width="800">
    <Window.Resources>
        <Style x:Key="RoundedTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A017" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="4" />
            <Setter Property="Foreground"
                    Value="red" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- BACKGROUND  -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#2F5A3A"
                          Offset="0.3" />
            <GradientStop Color="#4F8A54"
                          Offset="0.5" />
            <GradientStop Color="#ffffff"
                          Offset="0.7" />
            <GradientStop Color="#7BBF7B"
                          Offset="0.8" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="539*" />
            <ColumnDefinition Width="261*" />
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Image/backgroundred.jpg"
                        Stretch="UniformToFill"
                        Opacity="0.65" />
        </Grid.Background>

        <!-- Notification -->
        <StackPanel x:Name="NotificationContainer"
                    Orientation="Vertical"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10"
                    Grid.ColumnSpan="2"
                    Panel.ZIndex="999" />

        <!-- Second border-->
        <Border Opacity="0.7"
                BorderThickness="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="540"
                Height="250"
                CornerRadius="15"
                Margin="0,112,0,0"
                BorderBrush="#FFD966"
                Grid.ColumnSpan="2">

            <Border.Effect>
                <DropShadowEffect Color="#222"
                                  BlurRadius="25"
                                  ShadowDepth="6"
                                  Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0.5,1"
                                         StartPoint="0.5,0"
                                         Opacity="0.9">
                        <GradientStop Color="#F7E7C3"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="65*" />
                    <RowDefinition Height="59*" />
                </Grid.RowDefinitions>

                <!-- LABEL Input PIN -->

                <!-- Input 6 number-->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,112,0,0"
                            Grid.RowSpan="2">

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                             x:Name="tb_Pin1"
                             Width="45"
                             Height="55"
                             FontSize="30"
                             MaxLength="1"
                             TextAlignment="Center"
                             Margin="5"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="PinTextBox_PreviewTextInput"
                             PreviewKeyDown="PinTextBox_PreviewKeyDown"
                             Opacity="0.7"
                             TextChanged="PinTextBox_TextChanged" />

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                             x:Name="tb_Pin2"
                             Width="45"
                             Height="55"
                             FontSize="30"
                             MaxLength="1"
                             TextAlignment="Center"
                             Margin="5"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="PinTextBox_PreviewTextInput"
                             PreviewKeyDown="PinTextBox_PreviewKeyDown"
                             Opacity="0.7"
                             TextChanged="PinTextBox_TextChanged" />

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                             x:Name="tb_Pin3"
                             Width="45"
                             Height="55"
                             FontSize="30"
                             MaxLength="1"
                             TextAlignment="Center"
                             Margin="5"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="PinTextBox_PreviewTextInput"
                             PreviewKeyDown="PinTextBox_PreviewKeyDown"
                             Opacity="0.7"
                             TextChanged="PinTextBox_TextChanged" />

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                             x:Name="tb_Pin4"
                             Width="45"
                             Height="55"
                             FontSize="30"
                             MaxLength="1"
                             TextAlignment="Center"
                             Margin="5"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="PinTextBox_PreviewTextInput"
                             PreviewKeyDown="PinTextBox_PreviewKeyDown"
                             Opacity="0.7"
                             TextChanged="PinTextBox_TextChanged" />

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                             x:Name="tb_Pin5"
                             Width="45"
                             Height="55"
                             FontSize="30"
                             MaxLength="1"
                             TextAlignment="Center"
                             Margin="5"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="PinTextBox_PreviewTextInput"
                             PreviewKeyDown="PinTextBox_PreviewKeyDown"
                             Opacity="0.7"
                             TextChanged="PinTextBox_TextChanged" />

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                             x:Name="tb_Pin6"
                             Width="45"
                             Height="55"
                             FontSize="30"
                             MaxLength="1"
                             TextAlignment="Center"
                             Margin="5"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="PinTextBox_PreviewTextInput"
                             PreviewKeyDown="PinTextBox_PreviewKeyDown"
                             Opacity="0.7"
                             TextChanged="PinTextBox_TextChanged" />

                </StackPanel>
                <Label Content="NHẬP MÃ PIN"
                       VerticalAlignment="Top"
                       FontSize="32"
                       FontWeight="Bold"
                       FontFamily="Montserrat"
                       Width="300"
                       HorizontalAlignment="Center"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center"
                       Foreground="#FFE20B0B"
                       Margin="0,30,0,0" />

            </Grid>
        </Border>
       <UniformGrid Rows="1" Columns="4" 
             HorizontalAlignment="Center" 
             Margin="0,310,0,0"
             Grid.ColumnSpan="2">

    <TextBlock Text="Đăng ký PIN"
               Foreground="#FFF3413C"
               FontSize="14"
               FontWeight="Bold"
               Cursor="Hand"
               MouseLeftButtonUp="RegisterPIN_Click"
               Height="30"
               FontFamily="Montserrat" />

    <TextBlock Text="Quên mã PIN"
               Foreground="#FFF3413C"
               FontSize="14"
               FontWeight="Bold"
               Cursor="Hand"
               MouseLeftButtonUp="ForgotPIN_Click"
               Height="30"
               FontFamily="Montserrat" />

    <TextBlock Text="Đổi mã PIN"
               Foreground="#FFF3413C"
               FontSize="14"
               FontWeight="Bold"
               Cursor="Hand"
               MouseLeftButtonUp="ChangePIN_Click"
               Height="30"
               FontFamily="Montserrat" />

    <TextBlock Text="Hướng dẫn sử dụng"
               Foreground="#FFF3413C"
               FontSize="14"
               FontWeight="Bold"
               Cursor="Hand"
               MouseLeftButtonUp="OpenGuide_Click"
               Height="30"
               FontFamily="Montserrat" />
</UniformGrid>



        <Label Content="© Văn bằng 2 - K02 TTHL, BDNV &amp; GDNN  số 2 2025-2026"
               HorizontalAlignment="Left"
               Margin="423,388,0,0"
               VerticalAlignment="Top"
               RenderTransformOrigin="2.048,-0.815"
               FontFamily="Montserrat"
               Grid.ColumnSpan="2"
               FontWeight="Bold"
               Foreground="Black" />

    </Grid>
</Window>
