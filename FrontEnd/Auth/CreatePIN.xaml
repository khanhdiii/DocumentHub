<Window x:Class="DocumentHub.FrontEnd.Auth.CreatePIN"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TẠO MÃ PIN"
        Height="550"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="RoundedPasswordBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A017" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Foreground"
                    Value="Black" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="PasswordChar"
                    Value="•" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin"
                    Value="10" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Cursor"
                                        Value="Hand" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#2F5A3A"
                          Offset="0.3" />
            <GradientStop Color="#4F8A54"
                          Offset="0.5" />
            <GradientStop Color="#ffffff"
                          Offset="0.7" />
            <GradientStop Color="#7BBF7B"
                          Offset="0.8" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Image/backgroundred.jpg"
                        Stretch="UniformToFill"
                        Opacity="0.65" />
        </Grid.Background>

        <Border Opacity="0.7"
                Width="580"
                Height="300"
                BorderBrush="#FFD966"
                Background="#F7E7C3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="15"
                BorderThickness="2">

            <StackPanel Orientation="Vertical">
                <Label Content="TẠO MÃ PIN"
                       Foreground="#FFE20B0B"
                       FontFamily="Montserrat"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,25" />

                <!-- Input new PIN  -->
                <Grid HorizontalAlignment="Center"
                      Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Content="Nhập mã PIN mới"
                           FontSize="18"
                           FontWeight="Bold"
                           FontFamily="Montserrat"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0" />

                    <PasswordBox Grid.Column="1"
                                 Style="{StaticResource RoundedPasswordBoxStyle}"
                                 x:Name="pb_NewPIN"
                                 Width="180"
                                 Height="40"
                                 FontSize="30"
                                 MaxLength="6"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="PinTextBox_PreviewTextInput"
                                 PreviewKeyDown="PinTextBox_PreviewKeyDown" />
                </Grid>

                <!-- Confirm PIN -->
                <Grid HorizontalAlignment="Center"
                      Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Content="Xác nhận PIN mới"
                           FontSize="18"
                           FontWeight="Bold"
                           FontFamily="Montserrat"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0" />

                    <PasswordBox Grid.Column="1"
                                 Style="{StaticResource RoundedPasswordBoxStyle}"
                                 x:Name="pb_ConfirmNewPIN"
                                 Width="180"
                                 Height="40"
                                 FontSize="30"
                                 MaxLength="6"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="PinTextBox_PreviewTextInput"
                                 PreviewKeyDown="PinTextBox_PreviewKeyDown" />
                </Grid>

                <TextBlock x:Name="tb_Message"
                           Text=""
                           FontFamily="Montserrat"
                           Foreground="#FFE20B0B"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="14" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button x:Name="btn_CreatePIN"
                            Content="Đổi Mã PIN"
                            FontFamily="Montserrat"
                            Width="150"
                            Height="45"
                            Background="#D4A017"
                            Foreground="White"
                            BorderBrush="#A08013"
                            BorderThickness="2"
                            Click="btn_CreatePIN_Click" />

                    <Button x:Name="btn_Cancel"
                            Content="Hủy Bỏ"
                            Width="150"
                            Height="45"
                            FontFamily="Montserrat"
                            Background="#FF222020"
                            Foreground="White"
                            BorderBrush="#A08013"
                            BorderThickness="2"
                            Click="btn_Cancel_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Label Content="© K02 - 2025"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               FontFamily="Montserrat"
               Margin="0,0,50,0" />
    </Grid>
</Window>
