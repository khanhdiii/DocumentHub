<Window x:Class="DocumentHub.FrontEnd.LoginForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentHub.FrontEnd"
        mc:Ignorable="d"
        Title="LoginForm" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD966"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="12" 
                        SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                      Margin="0" 
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- BACKGROUND  -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2F5A3A" Offset="0.3"/>
            <GradientStop Color="#4F8A54" Offset="0.5"/>
            <GradientStop Color="#ffffff" Offset="0.7"/>
            <GradientStop Color="#7BBF7B" Offset="0.8"/>
        </LinearGradientBrush>
    </Window.Background>


    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Image/backgroundyellow.png" Stretch="UniformToFill"/>
        </Grid.Background>
        <!-- Title -->
        <Label x:Name="lb_NameContent" Content="ĐĂNG NHẬP"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               FontSize="40"
               HorizontalContentAlignment="Center"
               FontWeight="Bold"
               Foreground="#FFD4BC1A"
               FontFamily="montserrat" Margin="0,30,0,0"/>

        <!-- Second border-->
        <Border
            Opacity="0.7"
            BorderThickness="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="541" Height="250"
            CornerRadius="15"
            Margin="0,40,0,0"
            BorderBrush="#FFD966">

            <Border.Effect>
                <DropShadowEffect Color="#222" BlurRadius="25" ShadowDepth="6" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="White" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="65*"/>
                    <RowDefinition Height="59*"/>
                </Grid.RowDefinitions>

                <!-- LABEL Input PIN -->
                <Label Content="NHẬP MÃ PIN"
                   VerticalAlignment="Top"
                   FontSize="26"
                   FontWeight="Bold"
                   FontFamily="Montserrat"
                   Width="200"
                   HorizontalAlignment="Center"
                   Margin="0,35,0,0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="#FFCFCD5E"/>

                <!-- Input 6 number-->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,112,0,0" Grid.RowSpan="2">

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                         x:Name="tb_Pin1" Width="45" Height="55" FontSize="30" MaxLength="1"
                         TextAlignment="Center" Margin="5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         PreviewKeyDown="PinTextBox_PreviewKeyDown"
                         Opacity="0.7"
                         TextChanged="PinTextBox_TextChanged"/>

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                         x:Name="tb_Pin2" Width="45" Height="55" FontSize="30" MaxLength="1"
                         TextAlignment="Center" Margin="5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         PreviewKeyDown="PinTextBox_PreviewKeyDown"
                         Opacity="0.7"
                         TextChanged="PinTextBox_TextChanged"/>

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                        x:Name="tb_Pin3" Width="45" Height="55" FontSize="30" MaxLength="1"
                         TextAlignment="Center" Margin="5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         PreviewKeyDown="PinTextBox_PreviewKeyDown"
                         Opacity="0.7"
                         TextChanged="PinTextBox_TextChanged"/>

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                        x:Name="tb_Pin4" Width="45" Height="55" FontSize="30" MaxLength="1"
                         TextAlignment="Center" Margin="5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         PreviewKeyDown="PinTextBox_PreviewKeyDown"
                         Opacity="0.7"
                         TextChanged="PinTextBox_TextChanged"/>

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                         x:Name="tb_Pin5" Width="45" Height="55" FontSize="30" MaxLength="1"
                         TextAlignment="Center" Margin="5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         PreviewKeyDown="PinTextBox_PreviewKeyDown"
                         Opacity="0.7"
                         TextChanged="PinTextBox_TextChanged"/>

                    <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                        x:Name="tb_Pin6" Width="45" Height="55" FontSize="30" MaxLength="1"
                         TextAlignment="Center" Margin="5"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="PinTextBox_PreviewTextInput"
                         PreviewKeyDown="PinTextBox_PreviewKeyDown"
                         Opacity="0.7"
                         TextChanged="PinTextBox_TextChanged"/>

                </StackPanel>
                <Label Content="NHẬP MÃ PIN"
                    VerticalAlignment="Top"
                    FontSize="26"
                    FontWeight="Bold"
                    FontFamily="Montserrat"
                    Width="200"
                    HorizontalAlignment="Center"
                    Margin="0,35,0,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Foreground="#FFE20B0B"/>
                <Label x:Name="lb_changePin"  FontFamily="Montserrat" Margin="0,58,64,0" Grid.Row="1" FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Label x:Name="lb_changePin1" Content="Quên mã pin" Foreground="#FFA89847"/>
                </Label>


            </Grid>
        </Border>
        <Label Content="© K02 - 2025" HorizontalAlignment="Left" Margin="682,385,0,0" VerticalAlignment="Top" RenderTransformOrigin="2.048,-0.815" FontFamily="Montserrat"/>

    </Grid>
</Window>
