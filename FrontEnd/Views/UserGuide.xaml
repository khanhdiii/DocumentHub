<UserControl x:Class="DocumentHub.FrontEnd.Views.UserGuide"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="600"
             MinWidth="900">
	<Grid Background="#F5F7FA" Margin="20">
		<TabControl>
			<!-- Tab Đăng nhập -->
			<TabItem Header="🔑 Đăng nhập">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Đăng nhập"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2B6BEA"
                                   Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Stretch="Uniform" Height="600">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Login.png"/>
								</Viewbox>
								<TextBlock Text="Người dùng nhập mã PIN gồm 6 số để truy cập hệ thống."
                                           FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Mở phần mềm sẽ hiển thị màn hình Đăng nhập" FontSize="14"/>
										<TextBlock Text="• Nhập mã PIN" FontSize="14"/>
										<TextBlock Text="• Sau khi đăng nhập thành công, chuyển đến màn hình chính." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Quên PIN -->
			<TabItem Header="❗ Quên PIN">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Quên mã PIN"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2B6BEA"
                                   Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Stretch="Uniform" Height="600">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/ForgotPIN.png"/>
								</Viewbox>
								<TextBlock Text="Cho phép người dùng tạo lại mã PIN khi không nhớ."
                                           FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Chọn chức năng Quên PIN trên màn hình đăng nhập." FontSize="14"/>
										<TextBlock Text="• Bước 2: Nhập thông tin xác thực (câu hỏi bảo mật, mật khẩu phụ)." FontSize="14"/>
										<TextBlock Text="• Bước 3: Nhấn Tạo mã PIN mới để hoàn tất." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Dashboard -->
			<TabItem Header="📊 Dashboard">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Dashboard"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2B6BEA"
                                   Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Stretch="Uniform" Height="600">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Dashboard.png"/>
								</Viewbox>
								<TextBlock Text="Dashboard cung cấp cái nhìn tổng quan về tiến độ xử lý văn bản và thống kê hoạt động."
                                           FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập Dashboard từ menu chính." FontSize="14"/>
										<TextBlock Text="• Bước 2: Xem tiến độ theo tháng/quý/năm." FontSize="14"/>
										<TextBlock Text="• Bước 3: Nhấn vào từng mục để xem chi tiết." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Phân tích -->
			<TabItem Header="📈 Phân tích">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Phân tích"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2B6BEA"
                                   Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Stretch="Uniform" Height="600">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Analytic.png"/>
								</Viewbox>
								<TextBlock Text="Màn hình Phân tích cung cấp biểu đồ và số liệu thống kê."
                                           FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập mục Phân tích từ menu chính." FontSize="14"/>
										<TextBlock Text="• Bước 2: Xem biểu đồ thống kê theo năm." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Văn bản đến -->
			<TabItem Header="📥 Văn bản đến">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Văn bản đến" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<TextBlock Text="Quản lý văn bản đến giúp người dùng tiếp nhận, phân loại và xử lý các văn bản được gửi đến đơn vị." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập mục Văn bản đến từ menu." FontSize="14"/>
										<Viewbox Height="300">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/IncomingDocument.png"/>
										</Viewbox>
										<TextBlock Text="• Bước 2: Nhập thông tin và nhấn nút lưu." FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/IncomingDocument2-2.png"/>
										</Viewbox>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/IncomingDocument2-3.png"/>
										</Viewbox>
										<TextBlock Text="• Bước 3: Xuất Excel và lưu file." FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/IncomingDocument3.png"/>
										</Viewbox>
										<TextBlock Text="Màn hình file Excel khi tải về" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/IncomingDocument3-1.png"/>
										</Viewbox>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Văn bản đi -->
			<TabItem Header="📤 Văn bản đi">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Văn bản đi" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<TextBlock Text="Cho phép soạn thảo, phê duyệt và gửi văn bản đến các đơn vị khác." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước sử dụng tương tự Văn bản đến" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/OutgoingDocument.png"/>
										</Viewbox>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Tiến độ công việc -->
			<TabItem Header="📈 Tiến độ công việc">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Tiến độ công việc" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Height="300">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/WorkProgress.png"/>
								</Viewbox>
								<TextBlock Text="Theo dõi trạng thái xử lý văn bản theo từng bước, phòng ban và người phụ trách." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Trường hợp 1: Lưu thông tin theo Quý" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/WorkProgress2-1.png"/>
										</Viewbox>
										<TextBlock Text="• Trường hợp 2: Lựa chọn Tháng" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/WorkProgress3.png"/>
										</Viewbox>
										<TextBlock Text="• Trường hợp 3: Lựa chọn Năm" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/WorkProgress4.png"/>
										</Viewbox>
										<TextBlock Text="• Trường hợp 4: Đột xuất" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/WorkProgress5.png"/>
										</Viewbox>
										<TextBlock Text="• Trường hợp 5: Chuyên đề" FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/WorkProgress6.png"/>
										</Viewbox>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Người tiếp nhận -->
			<TabItem Header="👤 Người tiếp nhận">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Người tiếp nhận" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Height="250">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/RecevingOfficer.png"/>
								</Viewbox>
								<TextBlock Text="Xác định ai là người phụ trách tiếp nhận văn bản đến." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập mục Người tiếp nhận từ menu." FontSize="14"/>
										<TextBlock Text="• Bước 2: Chọn chức năng sửa." FontSize="14"/>
										<TextBlock Text="• Bước 3: Lọc dữ liệu trong danh sách." FontSize="14"/>
										<TextBlock Text="• Bước 4: Chọn chức năng xóa." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Người ký duyệt -->
			<TabItem Header="✍️ Người ký duyệt">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Người ký duyệt" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Height="300">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Signer.png"/>
								</Viewbox>
								<TextBlock Text="Người ký duyệt là người có thẩm quyền phê duyệt văn bản trước khi ban hành hoặc chuyển tiếp." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập mục Người ký duyệt từ menu." FontSize="14"/>
										<TextBlock Text="• Bước 2: Thêm người ký, sau đó hiển thị trong màn hình Văn bản đến/đi." FontSize="14"/>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Signer2-1.png"/>
										</Viewbox>
										<Viewbox Height="250">
											<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Signer2-2.png"/>
										</Viewbox>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Người nhận -->
			<TabItem Header="📬 Người nhận">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Người nhận" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Height="300">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Recipient.png"/>
								</Viewbox>
								<TextBlock Text="Người nhận là người cuối cùng tiếp nhận văn bản sau khi đã được xử lý và ký duyệt." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập mục Người nhận từ menu." FontSize="14"/>
										<TextBlock Text="• Bước 2: Thực hiện các chức năng tương tự như các màn hình trước." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<!-- Tab Cán bộ -->
			<TabItem Header="👥 Cán bộ">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="20">
						<TextBlock Text="Chức năng: Cán bộ" FontSize="22" FontWeight="Bold" Foreground="#2B6BEA" Margin="0,0,0,15"/>
						<Border Background="#F9FBFF" CornerRadius="8" Padding="12" BorderBrush="#2B6BEA" BorderThickness="1">
							<StackPanel>
								<Viewbox Height="300">
									<Image Height="500" Source="pack://application:,,,/Assets/Image/Guideline/Person.png"/>
								</Viewbox>
								<TextBlock Text="Chức năng Cán bộ cho phép xác định các cá nhân liên quan đến văn bản, giúp theo dõi trách nhiệm và phối hợp xử lý hiệu quả." FontSize="14" Foreground="#333" Margin="0,10"/>
								<Expander Header="Hướng dẫn sử dụng" IsExpanded="True" Margin="0,10,0,0">
									<StackPanel Margin="12,0,0,0">
										<TextBlock Text="• Bước 1: Truy cập mục Người liên quan từ menu bên trái." FontSize="14"/>
										<TextBlock Text="• Bước 2: Thực hiện các chức năng thêm/sửa/xóa tương tự như các màn hình khác." FontSize="14"/>
									</StackPanel>
								</Expander>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
		</TabControl>
		<!-- Footer -->
		<TextBlock Text="© 2026 DocumentHub. All rights reserved." FontSize="12" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
	</Grid>
</UserControl>