<UserControl x:Class="DocumentHub.FrontEnd.Views.UserGuide"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
  <Grid Background="White"
        Margin="20">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- Tiêu đề -->
        <TextBlock Text="HƯỚNG DẪN SỬ DỤNG PHẦN MỀM"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="DarkBlue"
                   Margin="0,0,0,20" />

        <!-- Giới thiệu -->
        <TextBlock Text="1. Giới thiệu"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />
        <TextBlock Text="DocumentHub là nền tảng quản lý văn bản giúp đơn giản hóa quy trình xử lý, lưu trữ và phân tích tài liệu. Phần mềm hỗ trợ các chức năng như đăng nhập, tạo mã PIN, quản lý văn bản đến/đi, theo dõi tiến độ và thống kê phân tích."
                   TextWrapping="Wrap"
                   Margin="0,0,0,20" />

        <!-- Đăng nhập -->
        <Border BorderBrush="#2B6BEA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,20"
                Background="#F9FBFF">
          <StackPanel>
            <TextBlock Text="Chức năng: Đăng nhập"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2B6BEA"
                       Margin="0,0,0,10" />
            <Image Source="pack://application:,,,/Assets/Image/Guideline/Login.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />
            <TextBlock Text="Người dùng có thể đăng nhập bằng mã PIN gồm 6 số để truy cập hệ thống DocumentHub."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#333"
                       Margin="0,0,0,10" />
            <TextBlock Text="Hướng dẫn sử dụng:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2B6BEA"
                       Margin="0,10,0,6" />
            <StackPanel Margin="12,0,0,0">
              <TextBlock Text="• Mở phần đầu tiên sẽ hiển thị màn hình Đăng nhập"
                         FontSize="14"
                         Margin="0,2" />
              <TextBlock Text="• Nhập mã PIN"
                         FontSize="14"
                         Margin="0,2" />
              <TextBlock Text="• Sau khi đăng nhập thành công, bạn sẽ được chuyển đến màn hình chính."
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Main.png"
                     Height="250"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- CreateForgotPIN -->
        <Border BorderBrush="#2B6BEA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,20"
                Background="#F9FBFF">
          <StackPanel>
            <!-- Tiêu đề -->
            <TextBlock Text="Chức năng:  Tạo mã PIN cấp 2"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2B6BEA"
                       Margin="0,0,0,10" />

            <!-- Ảnh minh họa -->
            <Image Source="pack://application:,,,/Assets/Image/Guideline/CreateForgotPIN.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />

            <!-- Mô tả -->
            <TextBlock Text="Chức năng này cho phép người dùng tạo lại mã PIN khi quên, đảm bảo vẫn có thể đăng nhập và sử dụng hệ thống DocumentHub."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#333"
                       Margin="0,0,0,10" />

            <!-- Hướng dẫn -->
            <TextBlock Text="Hướng dẫn sử dụng:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2B6BEA"
                       Margin="0,10,0,6" />

            <StackPanel Margin="12,0,0,0">
              <!-- Bước 1 -->
              <TextBlock Text="• Bước 1: Khi đăng nhập khi chưa tạo mã pin cấp 2 thì màn hình sẽ chuyển đến màn hinh này. "
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/CreateForgotPIN.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 2 -->
              <TextBlock Text="• Bước 2: Nhập thông tin câu hỏi"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/CreateForgotPIN2.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 3 -->
              <TextBlock FontSize="14"
                         Margin="0,2">
                          <Run Text="• Bước 3: Nhập đầy đủ thông tin trong form và nhấn " />
                          <Run Text="Tạo mã PIN cấp 2"
                               FontWeight="Bold" />
              </TextBlock>

              <Image Source="pack://application:,,,/Assets/Image/Guideline/CreateForgotPIN4.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 4 -->
              <TextBlock FontSize="14"
                         Margin="0,2">
             <Run Text="• Bước 4: Tạo thành công và trở về màn hình" />
             <Run Text="Đăng nhập"
                  FontWeight="Bold" />
              </TextBlock>
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Login2.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ForgotPIN -->
        <Border BorderBrush="#2B6BEA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,20"
                Background="#F9FBFF">
          <StackPanel>
            <!-- Tiêu đề -->
            <TextBlock Text="Chức năng: Quên mã PIN"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2B6BEA"
                       Margin="0,0,0,10" />

            <!-- Ảnh minh họa tổng quan -->
            <Image Source="pack://application:,,,/Assets/Image/Guideline/ForgotPIN.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />

            <!-- Mô tả -->
            <TextBlock Text="Chức năng Quên mã PIN cho phép người dùng tạo lại mã PIN khi không nhớ, đảm bảo vẫn có thể đăng nhập và sử dụng hệ thống DocumentHub. Ở màn hình có 3 phần chính là phần nhập, ô Xác nhận và ô Trở lại(khi nhấn sẽ chuyến đến màn hình Đăng nhập)."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#333"
                       Margin="0,0,0,10" />

            <!-- Hướng dẫn -->
            <TextBlock Text="Hướng dẫn sử dụng:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2B6BEA"
                       Margin="0,10,0,6" />

            <StackPanel Margin="12,0,0,0">
              <!-- Bước 1 -->
              <TextBlock FontSize="14"
                         Margin="0,2">
                <Run Text="• Bước 1: Chọn chức năng " />
                <Run Text="Quên mã PIN"
                     FontWeight="Bold" />
                <Run Text=" trên màn hình đăng nhập." />
              </TextBlock>
              <Image Source="pack://application:,,,/Assets/Image/Guideline/ForgotPIN.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 2 -->
              <TextBlock Text="• Bước 2: Nhập thông tin xác thực (ví dụ: câu hỏi Họ và tên của bạn là gì?, Bạn sinh năm bao nhiêu?, nhập mật khẩu bảo mật )."
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/ForgotPIN2.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 3 -->
              <TextBlock FontSize="14"
                         Margin="0,2">
                <Run Text="• Bước 3: Nhập đầy đủ thông tin trong form và nhấn " />
                <Run Text="Tạo mã PIN mới."
                     FontWeight="Bold" />
                Khi nhập đúng thông tin thì màn hình sẽ chuyển đến màn hình
                 <TextBlock Text=" "
                            FontSize="14"
                            >
                   <Run Text="Tạo mã PIN"
                         FontWeight="Bold" />
                 </TextBlock>
              </TextBlock>

             
              <Image Source="pack://application:,,,/Assets/Image/Guideline/CreateForgotPIN4.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- CreatePIN -->
        <Border BorderBrush="#2B6BEA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,20"
                Background="#F9FBFF">
          <StackPanel>
            <!-- Tiêu đề -->
            <TextBlock Text="Chức năng: Tạo mã PIN"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2B6BEA"
                       Margin="0,0,0,10" />

            <!-- Ảnh minh họa tổng quan -->
            <Image Source="pack://application:,,,/Assets/Image/Guideline/CreatePIN.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />

            <!-- Mô tả -->
            <TextBlock Text="Tạo mã PIN giúp tạo lại Mã PIN khi đã xác thực qua bước Quên mã PIN"
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#333"
                       Margin="0,0,0,10" />

            <!-- Hướng dẫn -->
            <TextBlock Text="Hướng dẫn sử dụng:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2B6BEA"
                       Margin="0,10,0,6" />

            <StackPanel Margin="12,0,0,0">
              <!-- Bước 1 -->
              <TextBlock Text="• Bước 1: Nhập Mã PIN"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/CreatePIN.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 2 -->
              <TextBlock FontSize="14"
                         Margin="0,2">
        <Run Text="• Bước 2: Nhập đầy đủ thông tin và nhấn " />
        <Run Text="Tạo mã PIN"
                FontWeight="Bold" />
              </TextBlock>
              <TextBlock Text="Khi tạo thành công sẽ hiện thông báo và chuyển về màn hình đăng nhập"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/CreatePIN2.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Main -->
        <Border BorderBrush="#2B6BEA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,20"
                Background="#F9FBFF">
          <StackPanel>
            <!-- Tiêu đề -->
            <TextBlock Text="Chức năng: Màn hình chính"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2B6BEA"
                       Margin="0,0,0,10" />

            <!-- Ảnh minh họa tổng quan -->
            <Image Source="pack://application:,,,/Assets/Image/Guideline/Main.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />
            <Image Source="pack://application:,,,/Assets/Image/Guideline/Main2.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />

            <!-- Mô tả -->
            <TextBlock Text="Màn hình chính cung cấp giao diện tổng quan, nơi người dùng có thể truy cập nhanh đến các chức năng như Dashboard, Văn bản đến/đi, Tiến độ công việc, Phân tích và Quản lý nâng cao,... Ở đây 1. Hiển thị nội dung thông báo công việc trong tuần 2. Nút nhấn để hiện thị thông báo công việc trong tuần 3. Hiển thị Bar chứa các chức năng khác trong hệ thống 4. Dùng để thu nhỏ Bar để phóng to nội dung hơn."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#333"
                       Margin="0,0,0,10" />

            <!-- Hướng dẫn -->
            <TextBlock Text="Hướng dẫn sử dụng:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2B6BEA"
                       Margin="0,10,0,6" />

            <StackPanel Margin="12,0,0,0">
              <!-- Bước 1 -->
              <TextBlock Text="• Bước 1: Sau khi đăng nhập thành công, hệ thống sẽ tự động chuyển đến màn hình chính. và nhấn biểu tượng chuông ở góc trên bên phải sẽ hiển thị nội dung thông báo công việc trong tuần"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Main3.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 2 -->
              <TextBlock Text="• Bước 2: Sử dụng menu bên trái nhấn vào biểu tượng Bar ở góc trên bên phải để thu nhỏ menu"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Main4.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 3 -->
              <TextBlock Text="• Bước 3: Quan sát phần nội dung bên phải hiển thị chi tiết theo chức năng đã chọn."
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Main3.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Dashboard -->
        <Border BorderBrush="#2B6BEA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,20"
                Background="#F9FBFF">
          <StackPanel>
            <!-- Tiêu đề -->
            <TextBlock Text="Chức năng: Dashboard"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#2B6BEA"
                       Margin="0,0,0,10" />

            <!-- Ảnh minh họa tổng quan -->
            <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard.png"
                   Height="250"
                   Stretch="Uniform"
                   Margin="0,0,0,10" />

            <!-- Mô tả -->
            <TextBlock Text="Dashboard cung cấp cái nhìn tổng quan về tiến độ xử lý văn bản, trạng thái các phòng ban và thống kê hoạt động."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#333"
                       Margin="0,0,0,10" />

            <!-- Hướng dẫn -->
            <TextBlock Text="Hướng dẫn sử dụng:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#2B6BEA"
                       Margin="0,10,0,6" />

            <StackPanel Margin="12,0,0,0">
              <!-- Bước 1 -->
              <TextBlock Text="• Bước 1: Truy cập Dashboard từ menu chính."
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
              <TextBlock Text="Màn hình khi đã chuyển qua tháng khác"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard2.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 2 -->
              <TextBlock Text="• Bước 2: Khi chọn vào lực chọn Qúy thì sẽ hiển thị 3 quý trong 1 năm"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard3.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />

              <!-- Bước 3 -->
              <TextBlock Text="• Bước 3: Nhấn vào từng mục để xem chi tiết hoặc chuyển hướng đến chức năng liên quan."
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard3.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard4.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
              <TextBlock Text="Khi chỉ vào 1 ô lịch thì sẽ hiển thị công việc đến hạn"
                         FontSize="14"
                         Margin="0,2" />
              <Image Source="pack://application:,,,/Assets/Image/Guideline/Dashboard6.png"
                     Height="200"
                     Stretch="Uniform"
                     Margin="0,0,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Footer -->
        <TextBlock Text="© 2026 DocumentHub. All rights reserved."
                   FontSize="12"
                   Foreground="#888"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0" />

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
