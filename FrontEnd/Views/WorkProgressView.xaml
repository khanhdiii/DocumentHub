<UserControl x:Class="DocumentHub.FrontEnd.Views.WorkProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DocumentHub.FrontEnd.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1400">
  <UserControl.Resources>
    <conv:BoolToCheckConverter x:Key="BoolToCheckConverter" />
    <conv:BoolToVisibilityForWorkConverter x:Key="BoolToVisibilityForWorkConverter" />
    <!--  Modern color palette  -->
    <Color x:Key="PrimaryColor">#FF2B6BEA</Color>
    <Color x:Key="AccentColor">#FF00B894</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="MuterText">#FF6B7280</Color>
    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrush"
                     Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SurfaceBrush"
                     Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="MutedTextBrush"
                     Color="{StaticResource MuterText}" />

    <!--  Corner radius and spacing  -->
    <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
    <Thickness x:Key="CardPadding">14</Thickness>

    <!--  TextBox style  -->
    <Style x:Key="ModernTextBox"
           TargetType="TextBox">
      <Setter Property="FontFamily"
              Value="Montserrat" />
      <Setter Property="Background"
              Value="#FFF7F9FC" />
      <Setter Property="BorderBrush"
              Value="#FFE6EDF8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Padding"
              Value="4" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="FontSize"
              Value="12" />
      <Setter Property="VerticalContentAlignment"
              Value="Center" />
      <Setter Property="SnapsToDevicePixels"
              Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Export button style  -->
    <Style x:Key="ExportButtonStyle"
           TargetType="Button">
      <Setter Property="Background"
              Value="#FF2D89EF" />
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="Padding"
              Value="10,6" />
      <Setter Property="Margin"
              Value="5" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="BorderBrush"
              Value="#FF1E5AA8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="FontFamily"
              Value="Montserrat" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver"
                 Value="True">
          <Setter Property="Background"
                  Value="#FF1E5AA8" />
        </Trigger>
        <Trigger Property="IsPressed"
                 Value="True">
          <Setter Property="Background"
                  Value="#FF164A90" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <!--  ComboBox style  -->
    <Style x:Key="ModernComboBox"
           TargetType="ComboBox">
      <Setter Property="Background"
              Value="#FFF7F9FC" />
      <Setter Property="FontFamily"
              Value="Montserrat" />
      <Setter Property="BorderBrush"
              Value="#FFE6EDF8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Padding"
              Value="4,4" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="FontSize"
              Value="12" />
      <Setter Property="Foreground"
              Value="Black" />
      <Setter Property="SnapsToDevicePixels"
              Value="True" />
      <Setter Property="SnapsToDevicePixels"
              Value="True" />
      <Setter Property="Foreground"
              Value="Black" />
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ComboBoxItem">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Padding"
                    Value="6" />
            <Style.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Background"
                        Value="#FFEAF2FF" />
              </Trigger>
              <Trigger Property="IsSelected"
                       Value="True">
                <Setter Property="Background"
                        Value="#FFD6E4FF" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>

    </Style>

    <!--  DatePicker style  -->
    <Style x:Key="ModernDatePicker"
           TargetType="DatePicker">
      <Setter Property="Background"
              Value="#FFF7F9FC" />
      <Setter Property="BorderBrush"
              Value="#FFE6EDF8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="Padding"
              Value="4" />
    </Style>

    <!--  Style button function  -->
    <Style x:Key="ModernActionButton"
           TargetType="Button">
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="Padding"
              Value="4,4" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <!--  Hover  -->
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Background"
                        Value="Yellow" />
                <Setter Property="Cursor"
                        Value="Hand" />
              </Trigger>
              <!--  Click  -->
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter Property="Background"
                        Value="Yellow" />
                <Setter Property="Cursor"
                        Value="Hand" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>

      <!--  Default background color  -->
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0"
                               EndPoint="1,1">
            <GradientStop Offset="0"
                          Color="#FF2196F3" />
            <GradientStop Offset="1"
                          Color="#FF1976D2" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Button style  -->
    <Style x:Key="PrimaryButton"
           TargetType="Button">
      <Setter Property="Background"
              Value="{StaticResource PrimaryBrush}" />
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="Padding"
              Value="8,6" />
      <Setter Property="Margin"
              Value="6,0,0,0" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="BorderThickness"
              Value="0" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Opacity"
                        Value="0.92" />
              </Trigger>
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter Property="Opacity"
                        Value="0.85" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Card header text style  -->
    <Style x:Key="CardHeader"
           TargetType="TextBlock">
      <Setter Property="FontSize"
              Value="15" />
      <Setter Property="FontWeight"
              Value="Bold" />
      <Setter Property="Foreground"
              Value="{StaticResource PrimaryBrush}" />
    </Style>

    <!--  DataGrid styling for modern look  -->
    <Style x:Key="ModernDataGrid"
           TargetType="DataGrid">
      <Setter Property="RowBackground"
              Value="#FFF" />
      <Setter Property="AlternatingRowBackground"
              Value="#FFF8FBFF" />
      <Setter Property="GridLinesVisibility"
              Value="None" />
      <Setter Property="HeadersVisibility"
              Value="Column" />
      <Setter Property="ColumnHeaderHeight"
              Value="40" />
      <Setter Property="RowHeight"
              Value="38" />
      <Setter Property="Margin"
              Value="8" />
    </Style>

    <!--Style for button pagination-->
    <Style x:Key="PagingButtonStyle"
           TargetType="Button">
      <Setter Property="Background"
              Value="#FF2B6BEA" />
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="FontWeight"
              Value="Bold" />
      <Setter Property="Padding"
              Value="8,8" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="FontSize"
              Value="12" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="BorderBrush"
              Value="#FF1E5AA8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Background"
                        Value="#FF1E5AA8" />
              </Trigger>
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter Property="Background"
                        Value="#FF164A90" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid Background="#FFF2F5FB"
        Margin="10">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="1.3*" />
      <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>

    <!-- LEFT: Form input -->
    <Border Grid.Column="0"
            Background="White"
            CornerRadius="10"
            Padding="14"
            Margin="0,0,12,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="Thông tin Tiến độ Công việc"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{StaticResource PrimaryBrush}"
                     Margin="0,0,0,10" />

          <!-- Tên công việc -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Tên Công việc"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding WorkItem.Name}"
                     Style="{StaticResource ModernTextBox}" />
          </Grid>

          <!-- Ngày bắt đầu -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ngày bắt đầu"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.StartDate}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Thời hạn -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Thời hạn"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.Deadline}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Ngày thông báo gốc -->
          <!-- Thời hạn hoàn thành -->
          <TextBlock Text="Thời hạn hoàn thành"
                     FontWeight="Bold"
                     Foreground="{StaticResource PrimaryBrush}"
                     Margin="0,6,0,4" />

          <!-- Ngày thông báo -->
          <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ngày thông báo"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.NotificationDate}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Các lựa chọn thời hạn -->
          <StackPanel Margin="0,4">
            <!-- Các mốc thời gian cố định -->
            <WrapPanel Margin="0,2">
              <CheckBox Content="3 tháng"
                        IsChecked="{Binding WorkItem.Is3Months}"
                        Margin="2" />
              <CheckBox Content="6 tháng"
                        IsChecked="{Binding WorkItem.Is6Months}"
                        Margin="2" />
              <CheckBox Content="9 tháng"
                        IsChecked="{Binding WorkItem.Is9Months}"
                        Margin="2" />
              <CheckBox Content="Hàng năm"
                        IsChecked="{Binding WorkItem.IsYearly}"
                        Margin="2" />
            </WrapPanel>

            <!-- Theo tháng -->
            <GroupBox Header="Theo tháng"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Tháng"
                          IsChecked="{Binding WorkItem.IsMonth}"
                          Margin="2" />
                <ItemsControl ItemsSource="{Binding MonthOptions}"
                              Visibility="{Binding WorkItem.IsMonth, Converter={StaticResource BoolToVisibilityForWorkConverter}}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding MonthLabel}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Margin="2" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </GroupBox>

            <!-- Theo năm -->
            <GroupBox Header="Theo năm"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Năm"
                          IsChecked="{Binding WorkItem.IsYear}"
                          Margin="2" />
                <ItemsControl ItemsSource="{Binding YearOptions}"
                              Visibility="{Binding WorkItem.IsYear, Converter={StaticResource BoolToVisibilityForWorkConverter}}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding Year, StringFormat='Năm {0}'}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Margin="2" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </GroupBox>

            <!-- Đột xuất -->
            <GroupBox Header="Đột xuất"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Đột xuất"
                          IsChecked="{Binding WorkItem.IsSudden}"
                          Margin="2" />
                <DatePicker SelectedDate="{Binding WorkItem.SuddenDate}"
                            Visibility="{Binding WorkItem.IsSudden, Converter={StaticResource BoolToVisibilityForWorkConverter}}"
                            Style="{StaticResource ModernDatePicker}" />
              </StackPanel>
            </GroupBox>

            <!-- Chuyên đề -->
            <GroupBox Header="Chuyên đề"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Chuyên đề"
                          IsChecked="{Binding WorkItem.IsSeminar}"
                          Margin="2" />
                <DatePicker SelectedDate="{Binding WorkItem.SeminarDate}"
                            Visibility="{Binding WorkItem.IsSeminar, Converter={StaticResource BoolToVisibilityForWorkConverter}}"
                            Style="{StaticResource ModernDatePicker}" />
              </StackPanel>
            </GroupBox>
          </StackPanel>

          <!-- Người giao việc -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Người giao việc"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Assigners}"
                      SelectedItem="{Binding WorkItem.Assigner}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Người phụ trách -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Người phụ trách"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StaffList}"
                      SelectedItem="{Binding WorkItem.PersonInCharge}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Trạng thái -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Trạng thái"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding WorkItem.Status}"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Độ ưu tiên -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Độ ưu tiên"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding PriorityOptions}"
                      SelectedItem="{Binding WorkItem.Priority}"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Tiến độ (%) -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Tiến độ (%)"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <Slider Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding WorkItem.Progress}" />
            <TextBlock Grid.Column="2"
                       Text="{Binding WorkItem.Progress}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" />
          </Grid>

          <!-- Ngày hoàn thành thực tế -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ngày HT thực tế"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.ActualCompletionDate}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>
          <!-- Show result -->

          <!-- Button -->
          <StackPanel Orientation="Horizontal"
                      Margin="0,10,0,0">
            <Button Content="Lưu"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="Xóa"
                    Command="{Binding DeleteCommand}"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="Hoàn thành"
                    Command="{Binding CompleteCommand}"
                    Style="{StaticResource PrimaryButton}" />
          </StackPanel>
          <TextBlock Text="{Binding NotificationMessage}"
                     Foreground="{StaticResource AccentBrush}"
                     FontWeight="Bold"
                     TextWrapping="Wrap"
                     TextTrimming="CharacterEllipsis"
                     Margin="0,6,0,0"
                     MaxWidth="300" />

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- RIGHT: List-->
    <Border Grid.Column="1"
            Background="White"
            CornerRadius="10"
            Padding="14">
      <StackPanel>
        <TextBlock Text="Danh sách Công việc"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,10" />

        <TextBox Text="{Binding SearchKeyword}"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,10" />

        <DataGrid ItemsSource="{Binding WorkList}"
                  SelectedItem="{Binding SelectedWorkItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  Height="600"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
          <DataGrid.Columns>
            <DataGridTextColumn Header="ID"
                                Binding="{Binding Id}"
                                Width="50" />
            <DataGridTextColumn Header="Tên Công việc"
                                Binding="{Binding Name}"
                                Width="200" />
            <DataGridTextColumn Header="Ngày BD"
                                Binding="{Binding StartDate}"
                                Width="100" />
            <DataGridTextColumn Header="Thời hạn"
                                Binding="{Binding Deadline}"
                                Width="100" />
            <DataGridTextColumn Header="Tháng"
                                Binding="{Binding IsMonth, Converter={StaticResource BoolToCheckConverter}}"
                                Width="60" />
            <DataGridTextColumn Header="3 tháng"
                                Binding="{Binding Is3Months, Converter={StaticResource BoolToCheckConverter}}"
                                Width="70" />
            <DataGridTextColumn Header="6 tháng"
                                Binding="{Binding Is6Months, Converter={StaticResource BoolToCheckConverter}}"
                                Width="70" />
            <DataGridTextColumn Header="9 tháng"
                                Binding="{Binding Is9Months, Converter={StaticResource BoolToCheckConverter}}"
                                Width="70" />
            <DataGridTextColumn Header="Năm"
                                Binding="{Binding IsYear, Converter={StaticResource BoolToCheckConverter}}"
                                Width="60" />

            <DataGridTextColumn Header="Người phụ trách"
                                Binding="{Binding PersonInCharge.FullName}"
                                Width="150" />
            <DataGridTextColumn Header="Trạng thái"
                                Binding="{Binding Status}"
                                Width="120" />
            <DataGridTextColumn Header="Độ ưu tiên"
                                Binding="{Binding Priority}"
                                Width="100" />
            <DataGridTextColumn Header="Tiến độ (%)"
                                Binding="{Binding Progress}"
                                Width="80" />
            <DataGridTextColumn Header="Ngày HT thực tế"
                                Binding="{Binding ActualCompletionDate}"
                                Width="120" />
          </DataGrid.Columns>
        </DataGrid>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
