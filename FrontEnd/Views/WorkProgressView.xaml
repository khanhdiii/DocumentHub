<UserControl x:Class="DocumentHub.FrontEnd.Views.WorkProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             xmlns:conv="clr-namespace:DocumentHub.FrontEnd.Converters"
             xmlns:vm="clr-namespace:DocumentHub.ViewModel"
             xmlns:helpers="clr-namespace:DocumentHub.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1400">
  <UserControl.Resources>
    <!--Helpers suport-->
    <helpers:ProgressToBrushConverter x:Key="ProgressToBrushConverter" />
    <helpers:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />
    <helpers:StatusToBrushConverter x:Key="StatusToBrushConverter" />
    <conv:BoolToCheckConverter x:Key="BoolToCheckConverter" />
    <conv:BoolToVisibilityForWorkConverter x:Key="BoolToVisibilityForWorkConverter" />

    <!--  Modern color palette  -->
    <Color x:Key="PrimaryColor">#FF2B6BEA</Color>
    <Color x:Key="AccentColor">#FF00B894</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="MuterText">#FF6B7280</Color>
    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrush"
                     Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SurfaceBrush"
                     Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="MutedTextBrush"
                     Color="{StaticResource MuterText}" />

    <!--  Corner radius and spacing  -->
    <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
    <Thickness x:Key="CardPadding">14</Thickness>

    <!--  TextBox style  -->
    <Style x:Key="ModernTextBox"
           TargetType="TextBox">
      <Setter Property="FontFamily"
              Value="Montserrat" />
      <Setter Property="Background"
              Value="#FFF7F9FC" />
      <Setter Property="BorderBrush"
              Value="#FFE6EDF8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Padding"
              Value="4" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="FontSize"
              Value="12" />
      <Setter Property="VerticalContentAlignment"
              Value="Center" />
      <Setter Property="SnapsToDevicePixels"
              Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Export button style  -->
    <Style x:Key="ExportButtonStyle"
           TargetType="Button">
      <Setter Property="Background"
              Value="#FF2D89EF" />
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="Padding"
              Value="10,6" />
      <Setter Property="Margin"
              Value="5" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="BorderBrush"
              Value="#FF1E5AA8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="FontFamily"
              Value="Montserrat" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver"
                 Value="True">
          <Setter Property="Background"
                  Value="#FF1E5AA8" />
        </Trigger>
        <Trigger Property="IsPressed"
                 Value="True">
          <Setter Property="Background"
                  Value="#FF164A90" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <!--  ComboBox style  -->
    <Style x:Key="ModernComboBox"
           TargetType="ComboBox">
      <Setter Property="Background"
              Value="#FFF7F9FC" />
      <Setter Property="FontFamily"
              Value="Montserrat" />
      <Setter Property="BorderBrush"
              Value="#FFE6EDF8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Padding"
              Value="4,4" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="FontSize"
              Value="12" />
      <Setter Property="Foreground"
              Value="Black" />
      <Setter Property="SnapsToDevicePixels"
              Value="True" />
      <Setter Property="SnapsToDevicePixels"
              Value="True" />
      <Setter Property="Foreground"
              Value="Black" />
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ComboBoxItem">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Padding"
                    Value="6" />
            <Style.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Background"
                        Value="#FFEAF2FF" />
              </Trigger>
              <Trigger Property="IsSelected"
                       Value="True">
                <Setter Property="Background"
                        Value="#FFD6E4FF" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>

    </Style>

    <!--  DatePicker style  -->
    <Style x:Key="ModernDatePicker"
           TargetType="DatePicker">
      <Setter Property="Background"
              Value="#FFF7F9FC" />
      <Setter Property="BorderBrush"
              Value="#FFE6EDF8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="Padding"
              Value="4" />
    </Style>

    <!--  Style button function  -->
    <Style x:Key="ModernActionButton"
           TargetType="Button">
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="Padding"
              Value="4,4" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <!--  Hover  -->
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Background"
                        Value="Yellow" />
                <Setter Property="Cursor"
                        Value="Hand" />
              </Trigger>
              <!--  Click  -->
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter Property="Background"
                        Value="Yellow" />
                <Setter Property="Cursor"
                        Value="Hand" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>

      <!--  Default background color  -->
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0"
                               EndPoint="1,1">
            <GradientStop Offset="0"
                          Color="#FF2196F3" />
            <GradientStop Offset="1"
                          Color="#FF1976D2" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Button style  -->
    <Style x:Key="PrimaryButton"
           TargetType="Button">
      <Setter Property="Background"
              Value="{StaticResource PrimaryBrush}" />
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="Padding"
              Value="8,6" />
      <Setter Property="Margin"
              Value="6,0,0,0" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="BorderThickness"
              Value="0" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Opacity"
                        Value="0.92" />
              </Trigger>
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter Property="Opacity"
                        Value="0.85" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Card header text style  -->
    <Style x:Key="CardHeader"
           TargetType="TextBlock">
      <Setter Property="FontSize"
              Value="15" />
      <Setter Property="FontWeight"
              Value="Bold" />
      <Setter Property="Foreground"
              Value="{StaticResource PrimaryBrush}" />
    </Style>

    <!--  DataGrid styling for modern look  -->
    <Style x:Key="ModernDataGrid"
           TargetType="DataGrid">
      <Setter Property="RowBackground"
              Value="#FFF" />
      <Setter Property="AlternatingRowBackground"
              Value="#FFF8FBFF" />
      <Setter Property="GridLinesVisibility"
              Value="None" />
      <Setter Property="HeadersVisibility"
              Value="Column" />
      <Setter Property="ColumnHeaderHeight"
              Value="40" />
      <Setter Property="RowHeight"
              Value="38" />
      <Setter Property="Margin"
              Value="8" />
    </Style>

    <!--Style for button pagination-->
    <Style x:Key="PagingButtonStyle"
           TargetType="Button">
      <Setter Property="Background"
              Value="#FF2B6BEA" />
      <Setter Property="Foreground"
              Value="White" />
      <Setter Property="FontWeight"
              Value="Bold" />
      <Setter Property="Padding"
              Value="8,8" />
      <Setter Property="Margin"
              Value="4" />
      <Setter Property="FontSize"
              Value="12" />
      <Setter Property="Cursor"
              Value="Hand" />
      <Setter Property="BorderBrush"
              Value="#FF1E5AA8" />
      <Setter Property="BorderThickness"
              Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter Property="Background"
                        Value="#FF1E5AA8" />
              </Trigger>
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter Property="Background"
                        Value="#FF164A90" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--Style for content datagrid-->
    <Style x:Key="CenterCellStyle"
           TargetType="DataGridCell">
      <Setter Property="HorizontalContentAlignment"
              Value="Center" />
      <Setter Property="VerticalContentAlignment"
              Value="Center" />
    </Style>

  </UserControl.Resources>

  <Grid Background="#FFF2F5FB"
        Margin="10">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="1.3*" />
      <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>

    <!-- LEFT: Form input -->
    <Border Grid.Column="0"
            Background="White"
            CornerRadius="10"
            Padding="14"
            Margin="0,0,12,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="Thông tin Tiến độ Công việc"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{StaticResource PrimaryBrush}"
                     Margin="0,0,0,10" />

          <!-- Tên công việc -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Label  * -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="Tên Công việc"
                         Grid.Column="0"
                         VerticalAlignment="Center" />
              <TextBlock Text="*"
                         Foreground="Red"
                         FontWeight="Bold"
                         Margin="4,0,0,0"
                         ToolTip="Trường này bắt buộc nhập" />
            </StackPanel>
            <TextBox Grid.Column="1"
                     Text="{Binding WorkItem.Name}"
                     Style="{StaticResource ModernTextBox}" />
          </Grid>

          <!-- Ngày bắt đầu -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ngày bắt đầu"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.StartDate}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Thời hạn -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Thời hạn"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.Deadline}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Ngày thông báo gốc -->
          <!-- Thời hạn hoàn thành -->
          <TextBlock Text="Thời hạn hoàn thành"
                     FontWeight="Bold"
                     Foreground="{StaticResource PrimaryBrush}"
                     Margin="0,6,0,4" />

          <!-- Ngày thông báo -->
          <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ngày thông báo"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.NotificationDate}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Các lựa chọn thời hạn -->
          <StackPanel Margin="0,4">
            <!-- Các mốc thời gian cố định -->
            <WrapPanel Margin="0,2">
              <CheckBox Content="Qúy 1"
                        IsChecked="{Binding WorkItem.Is3Months}"
                        Margin="2" />
              <CheckBox Content="Qúy 2"
                        IsChecked="{Binding WorkItem.Is6Months}"
                        Margin="2" />
              <CheckBox Content="Qúy 3"
                        IsChecked="{Binding WorkItem.Is9Months}"
                        Margin="2" />
              <CheckBox Content="Qúy 4"
                        IsChecked="{Binding WorkItem.Is11Months}"
                        Margin="2" />
            </WrapPanel>

            <!-- Theo tháng -->
            <GroupBox Header="Theo tháng"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Tháng"
                          IsChecked="{Binding WorkItem.IsMonth}"
                          Margin="2" />
                <ItemsControl ItemsSource="{Binding MonthOptions}"
                              Visibility="{Binding WorkItem.IsMonth, Converter={StaticResource BoolToVisibilityForWorkConverter}}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding MonthLabel}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Margin="2" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </GroupBox>

            <!-- Theo năm -->
            <GroupBox Header="Theo năm"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Năm"
                          IsChecked="{Binding WorkItem.IsYear}"
                          Margin="2" />
                <ItemsControl ItemsSource="{Binding YearOptions}"
                              Visibility="{Binding WorkItem.IsYear, Converter={StaticResource BoolToVisibilityForWorkConverter}}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding Year, StringFormat='Năm {0}'}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Margin="2" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </GroupBox>

            <!-- Đột xuất -->
            <GroupBox Header="Đột xuất"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Đột xuất"
                          IsChecked="{Binding WorkItem.IsSudden}"
                          Margin="2" />
                <DatePicker SelectedDate="{Binding WorkItem.SuddenDate}"
                            Visibility="{Binding WorkItem.IsSudden, Converter={StaticResource BoolToVisibilityForWorkConverter}}"
                            Style="{StaticResource ModernDatePicker}" />
              </StackPanel>
            </GroupBox>

            <!-- Chuyên đề -->
            <GroupBox Header="Chuyên đề"
                      Margin="0,4">
              <StackPanel>
                <CheckBox Content="Chuyên đề"
                          IsChecked="{Binding WorkItem.IsSeminar}"
                          Margin="2" />
                <DatePicker SelectedDate="{Binding WorkItem.SeminarDate}"
                            Visibility="{Binding WorkItem.IsSeminar, Converter={StaticResource BoolToVisibilityForWorkConverter}}"
                            Style="{StaticResource ModernDatePicker}" />
              </StackPanel>
            </GroupBox>
          </StackPanel>

          <!-- Người giao việc -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="Người giao việc"
                         Grid.Column="0"
                         VerticalAlignment="Center" />
              <TextBlock Text="*"
                         Foreground="Red"
                         FontWeight="Bold"
                         Margin="4,0,0,0"
                         ToolTip="Trường này bắt buộc nhập" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StaffOptions}"
                      SelectedItem="{Binding WorkItem.Assigner, Mode=TwoWay}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Người phụ trách -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="Người phụ trách"
                         Grid.Column="0"
                         VerticalAlignment="Center" />
              <TextBlock Text="*"
                         Foreground="Red"
                         FontWeight="Bold"
                         Margin="4,0,0,0"
                         ToolTip="Trường này bắt buộc nhập" />
            </StackPanel>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StaffOptions}"
                      SelectedItem="{Binding WorkItem.PersonInCharge, Mode=TwoWay}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Trạng thái -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="Trạng thái"
                         Grid.Column="0"
                         VerticalAlignment="Center" />
              <TextBlock Text="*"
                         Foreground="Red"
                         FontWeight="Bold"
                         Margin="4,0,0,0"
                         ToolTip="Trường này bắt buộc nhập" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding WorkItem.Status}"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Độ ưu tiên -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="Độ ưu tiên"
                         Grid.Column="0"
                         VerticalAlignment="Center" />
              <TextBlock Text="*"
                         Foreground="Red"
                         FontWeight="Bold"
                         Margin="4,0,0,0"
                         ToolTip="Trường này bắt buộc nhập" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding PriorityOptions}"
                      SelectedItem="{Binding WorkItem.Priority}"
                      Style="{StaticResource ModernComboBox}" />
          </Grid>

          <!-- Tiến độ (%) -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Tiến độ (%)"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <Slider Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding WorkItem.Progress}" />
            <TextBlock Grid.Column="2"
                       Text="{Binding WorkItem.Progress, StringFormat={}{0}%}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" />
          </Grid>

          <!-- Ngày hoàn thành thực tế -->
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ngày HT thực tế"
                       Grid.Column="0"
                       VerticalAlignment="Center" />
            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding WorkItem.ActualCompletionDate}"
                        Style="{StaticResource ModernDatePicker}" />
          </Grid>

          <!-- Button -->
          <StackPanel Orientation="Horizontal"
                      Margin="0,10,0,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <Button Content="Lưu"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Width="300" />
          </StackPanel>
          <TextBlock Text="{Binding NotificationMessage}"
                     Foreground="{StaticResource AccentBrush}"
                     FontWeight="Bold"
                     TextWrapping="Wrap"
                     TextTrimming="CharacterEllipsis"
                     Margin="0,6,0,0"
                     MaxWidth="300" />

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- RIGHT: List-->
    <Border Grid.Column="1"
            Background="White"
            CornerRadius="10"
            Padding="14">
      <StackPanel>
        <TextBlock Text="Danh sách Công việc"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,10" />

        <Grid>
          <!-- TextBox tìm kiếm -->
          <TextBox x:Name="SearchBox"
                   Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource ModernTextBox}"
                   Margin="0,0,0,10" />

          <!-- Placeholder -->
          <TextBlock Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource MutedTextBrush}"
                     IsHitTestVisible="False"
                     Text="Tìm kiếm theo Tên công việc, Ngày...">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility"
                        Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                               Value="">
                    <Setter Property="Visibility"
                            Value="Visible" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                               Value="{x:Null}">
                    <Setter Property="Visibility"
                            Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>
        
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,0">
          <TextBlock Text="Từ"
                     VerticalAlignment="Center"
                     Margin="4" />
          <DatePicker SelectedDate="{Binding SearchDateFrom}"
                      Width="120"
                      Margin="4" />
          <TextBlock Text="đến"
                     VerticalAlignment="Center"
                     Margin="4" />
          <DatePicker SelectedDate="{Binding SearchDateTo}"
                      Width="120"
                      Margin="4" />
          <Button Command="{Binding ApplyFilterCommand}"
                  Padding="10,6"
                  Margin="4"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
              <fa:ImageAwesome Icon="Filter"
                               Width="16"
                               Height="16"
                               Foreground="White"
                               Margin="0,0,6,0" />

            </StackPanel>
          </Button>

          <!-- Button Clear -->
          <Button Command="{Binding ClearFilterCommand}"
                  Style="{StaticResource PrimaryButton}"
                  Padding="10,6"
                  Margin="4"
                  Cursor="Hand"
                  Background="#FFEF5350">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
              <TextBlock Text="Clear"
                         Foreground="White"
                         FontWeight="SemiBold" />
            </StackPanel>
          </Button>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,10,0,0">
            <!-- Button Lọc -->
            
          </StackPanel>
        </StackPanel>

        <!--Datagrid-->
        <DataGrid AutoGenerateColumns="False"
                  SelectedItem="{Binding SelectedWorkItem, Mode=TwoWay}"
                  ItemsSource="{Binding PagedWorkList}"
                  Style="{StaticResource ModernDataGrid}">
          <DataGrid.ColumnHeaderStyle>
            <Style TargetType="DataGridColumnHeader">
              <Setter Property="FontWeight"
                      Value="Bold" />
              <Setter Property="HorizontalContentAlignment"
                      Value="Center" />
            </Style>
          </DataGrid.ColumnHeaderStyle>

          <DataGrid.Columns>
            <DataGridTemplateColumn Header="Tên Công việc"
                                    Width="auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Ngày bắt đầu"
                                    Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Thời hạn"
                                    Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Deadline, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>


            <DataGridTemplateColumn Header="Đột xuất"
                                    Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding SuddenDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Chuyên đề"
                                    Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding SeminarDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Ngày thông báo (Tháng)"
                                    Width="auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding MonthNotifyDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Ngày thông báo (Quý)"
                                    Width="auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding QuarterNotifyDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Ngày thông báo (Năm)"
                                    Width="auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding YearNotifyDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Người giao việc"
                                    Width="200">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Assigner.FullName}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Người phụ trách"
                                    Width="200">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding PersonInCharge.FullName}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Trạng thái"
                                    Width="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Status}"
                             HorizontalAlignment="Center"
                             FontWeight="Bold"
                             Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Độ ưu tiên"
                                    Width="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Priority}"
                             HorizontalAlignment="Center"
                             FontWeight="Bold"
                             Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Tiến độ (%)"
                                    Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Progress}"
                             HorizontalAlignment="Center"
                             FontWeight="Bold"
                             Foreground="{Binding Progress, Converter={StaticResource ProgressToBrushConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Ngày HT thực tế"
                                    Width="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding ActualCompletionDate, StringFormat={}{0:dd/MM/yyyy}}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!--  Actions  -->
            <DataGridTemplateColumn Width="120"
                                    Header="Thao tác">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel HorizontalAlignment="Center"
                              Orientation="Horizontal">
                    <!--  Edit button  -->
                    <Button Margin="4"
                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ModernActionButton}">
                      <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Width="14"
                                         Height="14"
                                         Foreground="White"
                                         Icon="Edit" />
                      </StackPanel>
                    </Button>

                    <!--  Delete button  -->
                    <Button Margin="4"
                            Background="Red"
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ModernActionButton}">
                      <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Width="14"
                                         Height="14"
                                         Foreground="White"
                                         Icon="Trash" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
        <!--Pagination datagrid-->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">
          <!-- Go first page -->
          <Button Command="{Binding GoToFirstPageCommand}"
                  Style="{StaticResource PagingButtonStyle}">
            <fa:ImageAwesome Icon="StepBackward"
                             Width="16"
                             Height="16"
                             Foreground="White" />
          </Button>

          <!-- Prev page -->
          <Button Command="{Binding PreviousPageCommand}"
                  Style="{StaticResource PagingButtonStyle}">
            <fa:ImageAwesome Icon="ChevronLeft"
                             Width="16"
                             Height="16"
                             Foreground="White" />
          </Button>

          <!-- Show page number -->
          <TextBlock Text="{Binding CurrentPage}"
                     Margin="10,0"
                     VerticalAlignment="Center"
                     FontWeight="Bold"
                     FontSize="14" />
          <TextBlock Text="/"
                     Margin="2,0"
                     VerticalAlignment="Center"
                     FontSize="14" />
          <TextBlock Text="{Binding TotalPages}"
                     Margin="2,0"
                     VerticalAlignment="Center"
                     FontSize="14" />

          <!-- Next page -->
          <Button Command="{Binding NextPageCommand}"
                  Style="{StaticResource PagingButtonStyle}">
            <fa:ImageAwesome Icon="ChevronRight"
                             Width="16"
                             Height="16"
                             Foreground="White" />
          </Button>

          <!-- Last page -->
          <Button Command="{Binding GoToLastPageCommand}"
                  Style="{StaticResource PagingButtonStyle}">
            <fa:ImageAwesome Icon="StepForward"
                             Width="16"
                             Height="16"
                             Foreground="White" />
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
