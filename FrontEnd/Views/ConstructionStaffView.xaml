<UserControl x:Class="DocumentHub.FrontEnd.Views.ConstructionStaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DocumentHub.FrontEnd.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF">

        <UserControl.Resources>
            <!-- Modern color palette -->
            <Color x:Key="PrimaryColor">#FF2B6BEA</Color>
            <Color x:Key="AccentColor">#FF00B894</Color>
            <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
            <Color x:Key="MuterText">#FF6B7280</Color>
            <SolidColorBrush x:Key="PrimaryBrush"
                                 Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="AccentBrush"
                                 Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="SurfaceBrush"
                                 Color="{StaticResource SurfaceColor}"/>
            <SolidColorBrush x:Key="MutedTextBrush"
                                 Color="{StaticResource MuterText}"/>

            <!-- Corner radius and spacing -->
            <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
            <Thickness x:Key="CardPadding">14</Thickness>

            <!-- TextBox style -->
            <Style TargetType="TextBox"
                       x:Key="ModernTextBox">
                <Setter Property="FontFamily"
                                Value="Montserrat"/>
                <Setter Property="Background"
                                Value="#FFF7F9FC"/>
                <Setter Property="BorderBrush"
                                Value="#FFE6EDF8"/>
                <Setter Property="BorderThickness"
                                Value="1"/>
                <Setter Property="Padding"
                                Value="4"/>
                <Setter Property="Margin"
                                Value="4"/>
                <Setter Property="FontSize"
                                Value="12"/>
                <Setter Property="VerticalContentAlignment"
                                Value="Center"/>
                <Setter Property="SnapsToDevicePixels"
                                Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Export button style -->
            <Style x:Key="ExportButtonStyle"
                       TargetType="Button">
                <Setter Property="Background"
                                Value="#FF2D89EF"/>
                <Setter Property="Foreground"
                                Value="White"/>
                <Setter Property="FontWeight"
                                Value="SemiBold"/>
                <Setter Property="Padding"
                                Value="10,6"/>
                <Setter Property="Margin"
                                Value="5"/>
                <Setter Property="Cursor"
                                Value="Hand"/>
                <Setter Property="BorderBrush"
                                Value="#FF1E5AA8"/>
                <Setter Property="BorderThickness"
                                Value="1"/>
                <Setter Property="FontFamily"
                                Value="Montserrat"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                                         Value="True">
                        <Setter Property="Background"
                                                Value="#FF1E5AA8"/>
                    </Trigger>
                    <Trigger Property="IsPressed"
                                         Value="True">
                        <Setter Property="Background"
                                                Value="#FF164A90"/>
                    </Trigger>
                </Style.Triggers>
            </Style>


            <!-- ComboBox style -->
            <Style TargetType="ComboBox"
                       x:Key="ModernComboBox">
                <Setter Property="Background"
                                Value="#FFF7F9FC"/>
                <Setter Property="FontFamily"
                                Value="Montserrat"/>
                <Setter Property="BorderBrush"
                                Value="#FFE6EDF8"/>
                <Setter Property="BorderThickness"
                                Value="1"/>
                <Setter Property="Padding"
                                Value="4,4"/>
                <Setter Property="Margin"
                                Value="4"/>
                <Setter Property="FontSize"
                                Value="12"/>
                <Setter Property="Foreground"
                                Value="Black"/>
                <Setter Property="SnapsToDevicePixels"
                                Value="True"/>
                <Setter Property="SnapsToDevicePixels"
                                Value="True"/>
                <Setter Property="Foreground"
                                Value="Black"/>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background"
                                                        Value="White"/>
                            <Setter Property="Padding"
                                                        Value="6"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                    <Setter Property="Background"
                                                                        Value="#FFEAF2FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected"
                                                                 Value="True">
                                    <Setter Property="Background"
                                                                        Value="#FFD6E4FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>

            </Style>



            <!-- DatePicker style -->
            <Style TargetType="DatePicker"
                       x:Key="ModernDatePicker">
                <Setter Property="Background"
                                Value="#FFF7F9FC"/>
                <Setter Property="BorderBrush"
                                Value="#FFE6EDF8"/>
                <Setter Property="BorderThickness"
                                Value="1"/>
                <Setter Property="Margin"
                                Value="4"/>
                <Setter Property="Padding"
                                Value="4"/>
            </Style>

            <Style TargetType="Button"
                       x:Key="ModernActionButton">
                <Setter Property="Foreground"
                                Value="White"/>
                <Setter Property="FontWeight"
                                Value="SemiBold"/>
                <Setter Property="Padding"
                                Value="4,4"/>
                <Setter Property="Margin"
                                Value="4"/>
                <Setter Property="Cursor"
                                Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Hover -->
                                <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                    <Setter Property="Background"
                                                                        Value="Yellow"/>
                                    <Setter Property="Cursor"
                                                                        Value="Hand"/>
                                    <!-- xanh lá -->
                                </Trigger>
                                <!-- Click -->
                                <Trigger Property="IsPressed"
                                                                 Value="True">
                                    <Setter Property="Background"
                                                                        Value="Yellow"/>
                                    <Setter Property="Cursor"
                                                                        Value="Hand"/>
                                    <!-- xanh đậm -->
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <!-- Màu nền mặc định -->
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,1">
                            <GradientStop Color="#FF2196F3"
                                                              Offset="0"/>
                            <!-- xanh dương -->
                            <GradientStop Color="#FF1976D2"
                                                              Offset="1"/>
                            <!-- xanh đậm -->
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>


            <!-- Button style -->
            <Style TargetType="Button"
                       x:Key="PrimaryButton">
                <Setter Property="Background"
                                Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Foreground"
                                Value="White"/>
                <Setter Property="Padding"
                                Value="8,6"/>
                <Setter Property="Margin"
                                Value="6,0,0,0"/>
                <Setter Property="FontWeight"
                                Value="SemiBold"/>
                <Setter Property="BorderThickness"
                                Value="0"/>
                <Setter Property="Cursor"
                                Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                    <Setter Property="Opacity"
                                                                        Value="0.92"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                                                 Value="True">
                                    <Setter Property="Opacity"
                                                                        Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Card header text style -->
            <Style TargetType="TextBlock"
                       x:Key="CardHeader">
                <Setter Property="FontSize"
                                Value="15"/>
                <Setter Property="FontWeight"
                                Value="Bold"/>
                <Setter Property="Foreground"
                                Value="{StaticResource PrimaryBrush}"/>
            </Style>

            <!-- DataGrid styling for modern look -->
            <Style TargetType="DataGrid"
                       x:Key="ModernDataGrid">
                <Setter Property="RowBackground"
                                Value="#FFF"/>
                <Setter Property="AlternatingRowBackground"
                                Value="#FFF8FBFF"/>
                <Setter Property="GridLinesVisibility"
                                Value="None"/>
                <Setter Property="HeadersVisibility"
                                Value="Column"/>
                <Setter Property="ColumnHeaderHeight"
                                Value="40"/>
                <Setter Property="RowHeight"
                                Value="38"/>
                <Setter Property="Margin"
                                Value="8"/>
            </Style>
        </UserControl.Resources>


        <Grid Background="#FFF2F5FB"
              Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- Main content: left form, right list -->
            <!-- NOTE: removed ColumnSpacing (not supported in WPF). spacing is handled with margins below. -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Form input -->
                    <ColumnDefinition Width="0.85*"/>
                    <!-- List Table -->
                    <ColumnDefinition Width="3*"/>

                </Grid.ColumnDefinitions>
                <!-- Left card: input form -->
                <Border Grid.Column="0"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}"
                                Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}"
                                                   Text="Thông tin văn bản đi"
                                                   FontFamily="Montserrat"
                                                   Margin="0,0,0,8"/>

                        <!-- Cán bộ xử lý -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                                           Text="Cán bộ xử lý"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>

                            <TextBox Grid.Column="1"
                                                         Style="{StaticResource ModernTextBox}"
                                                         Text="{Binding SelectedDocument.Handler}"/>
                        </Grid>

                        <!-- Nút lưu -->
                        <Button Style="{StaticResource PrimaryButton}"
                                                Content="Lưu"
                                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>




                <!-- Right card: list -->
                <Border Grid.Column="1"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="{StaticResource CardPadding}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}"
                                                   Text="Danh sách văn bản đi"/>

                        <!-- Quick filter and search row -->
                        <DockPanel Margin="0,0,0,8">
                            <!-- Search box with watermark implemented (PlaceholderText not available in WPF) -->
                            <Grid DockPanel.Dock="Right"
                                                      Margin="0,4">
                                <TextBox x:Name="SearchBox"
                                                                 Style="{StaticResource ModernTextBox}"
                                                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                                                 VerticalContentAlignment="Center"/>
                                <TextBlock Text="Tìm kiếm theo Số đến, Người gửi..."
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   Margin="12,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                                                        Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                                                                     Value="">
                                                    <Setter Property="Visibility"
                                                                                                        Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                                                                     Value="{x:Null}">
                                                    <Setter Property="Visibility"
                                                                                                        Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                        </DockPanel>
                        <DataGrid x:Name="OutgoingDocsDataGrid"
                                                  FontFamily="Montserrat"
                                                  SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="False"
                                                  CanUserAddRows="False"
                                                  ItemsSource="{Binding FilteredDocs}"
                                                  EnableRowVirtualization="True"
                                                  SelectionMode="Extended"
                                                  HorizontalScrollBarVisibility="Visible"
                                                  VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.CanContentScroll="False">
                            <DataGrid.Resources>
                                <Style TargetType="{x:Type DataGridColumnHeader}">
                                    <Setter Property="FontWeight"
                                                                        Value="Bold"/>
                                    <Setter Property="FontFamily"
                                                                        Value="Montserrat"/>
                                    <Setter Property="FontSize"
                                                                        Value="13"/>
                                    <Setter Property="HorizontalContentAlignment"
                                                                        Value="Center"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Style>
                                <StaticResource ResourceKey="ModernDataGrid"/>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                              
                                <!-- ID-->
                                <DataGridTextColumn Header="ID"
                                                                            Binding="{Binding Id}"
                                                                            Width="30">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="HorizontalAlignment"
                                                                                        Value="Center"/>
                                            <Setter Property="VerticalAlignment"
                                                                                        Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="{x:Type TextBox}">
                                            <Setter Property="HorizontalContentAlignment"
                                                                                        Value="Center"/>
                                            <Setter Property="VerticalContentAlignment"
                                                                                        Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>

                                <!-- Cán bộ xử lý -->
                                <DataGridTextColumn Header="Cán Bộ XD"
                                                                            Binding="{Binding Handler}"
                                                                            Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="HorizontalAlignment"
                                                                                        Value="Center"/>
                                            <Setter Property="VerticalAlignment"
                                                                                        Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="{x:Type TextBox}">
                                            <Setter Property="HorizontalContentAlignment"
                                                                                        Value="Center"/>
                                            <Setter Property="VerticalContentAlignment"
                                                                                        Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>

                                <!-- Button function-->
                                <DataGridTemplateColumn Header="Thao tác"
                                                                                Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                                                            HorizontalAlignment="Center">
                                                <!-- Nút Sửa -->
                                                <Button Style="{StaticResource ModernActionButton}"
                                                                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                                                                CommandParameter="{Binding}"
                                                                                                Margin="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:ImageAwesome Icon="Edit"
                                                                                                                         Width="14"
                                                                                                                         Height="14"
                                                                                                                         Foreground="White"/>
                                                        <TextBlock  VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- Nút Xóa -->
                                                <Button Style="{StaticResource ModernActionButton}"
                                                                                                Background="Red"
                                                                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                                                                CommandParameter="{Binding}"
                                                                                                Margin="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:ImageAwesome Icon="Trash"
                                                                                                                         Width="14"
                                                                                                                         Height="14"
                                                                                                                         Foreground="White"/>
                                                        <TextBlock  VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                        </DataGrid>
                        <Button Style="{StaticResource ExportButtonStyle}"
                                                Command="{Binding ExportExcelCommand}">
                            <StackPanel Orientation="Horizontal">
                                <!-- Icon FontAwesome -->
                                <fa:FontAwesome Icon="Download"
                                                                        FontSize="14"
                                                                        Margin="0,0,6,0"/>
                                <!-- Text -->
                                <TextBlock Text="Xuất Excel"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </UserControl>