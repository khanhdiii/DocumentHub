<UserControl x:Class="DocumentHub.FrontEnd.Views.ConstructionStaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             xmlns:local="clr-namespace:DocumentHub.FrontEnd.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DocumentHub.ViewModel"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:ConstructionStaffViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!--  Modern color palette  -->
        <Color x:Key="PrimaryColor">#FF2B6BEA</Color>
        <Color x:Key="AccentColor">#FF00B894</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="MuterText">#FF6B7280</Color>

        <SolidColorBrush x:Key="PrimaryBrush"
                         Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"
                         Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="{StaticResource MuterText}" />

        <!--  Corner radius and spacing  -->
        <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
        <Thickness x:Key="CardPadding">14</Thickness>

        <!--  TextBox style  -->
        <Style x:Key="ModernTextBox"
               TargetType="TextBox">
            <Setter Property="FontFamily"
                    Value="Montserrat" />
            <Setter Property="Background"
                    Value="#FFF7F9FC" />
            <Setter Property="BorderBrush"
                    Value="#FFE6EDF8" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="4" />
            <Setter Property="Margin"
                    Value="4" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="SnapsToDevicePixels"
                    Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Button style  -->
        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Padding"
                    Value="8,6" />
            <Setter Property="Margin"
                    Value="50,0,0,0" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Width"
                    Value="200" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--Style for button pagination-->
        <Style x:Key="PagingButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FF2B6BEA" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Padding"
                    Value="8,8" />
            <Setter Property="Margin"
                    Value="4" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="BorderBrush"
                    Value="#FF1E5AA8" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#FF1E5AA8" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#FF164A90" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Style button function  -->
        <Style x:Key="ModernActionButton"
               TargetType="Button">
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Padding"
                    Value="4,4" />
            <Setter Property="Margin"
                    Value="4" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!--  Hover  -->
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="Yellow" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                            </Trigger>
                            <!--  Click  -->
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="Yellow" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!--  Default background color  -->
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Offset="0"
                                      Color="#FF2196F3" />
                        <GradientStop Offset="1"
                                      Color="#FF1976D2" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Card header text style  -->
        <Style x:Key="CardHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="{StaticResource PrimaryBrush}" />
        </Style>

        <!--  DataGrid styling  -->
        <Style x:Key="ModernDataGrid"
               TargetType="DataGrid">
            <Setter Property="RowBackground"
                    Value="#FFF" />
            <Setter Property="AlternatingRowBackground"
                    Value="#FFF8FBFF" />
            <Setter Property="GridLinesVisibility"
                    Value="None" />
            <Setter Property="HeadersVisibility"
                    Value="Column" />
            <Setter Property="ColumnHeaderHeight"
                    Value="40" />
            <Setter Property="RowHeight"
                    Value="38" />
            <Setter Property="Margin"
                    Value="8" />
            <Setter Property="Width"
                    Value="500" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="4"
          Background="#FFF2F5FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Main content  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!--  Left Form  -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="{StaticResource CardPadding}"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="{StaticResource CardCornerRadius}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,8"
                               FontFamily="Montserrat"
                               Style="{StaticResource CardHeader}"
                               Text="Thông tin cán bộ xử lý" />

                    <!--  Handler  -->
                    <Grid Margin="6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="300" />

                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="Cán bộ xử lý" />
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SelectedStaff.FullName, Mode=TwoWay}"
                                 Width="NaN" />
                    </Grid>

                    <!--  Save button  -->
                    <Button Margin="6,20,0,0"
                            Command="{Binding SaveCommand}"
                            Content="Lưu"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Border>

            <!--  Right card  -->
            <Border Grid.Column="1"
                    Padding="{StaticResource CardPadding}"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="{StaticResource CardCornerRadius}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardHeader}"
                               Text="Danh sách cán bộ xử lý" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="119*" />
                            <ColumnDefinition Width="328*" />
                        </Grid.ColumnDefinitions>
                        <!-- TextBox tìm kiếm -->
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10"
                                 Grid.ColumnSpan="2" />

                        <!-- Placeholder -->
                        <TextBlock Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   IsHitTestVisible="False"
                                   Text="Tìm kiếm theo Tên công việc, Ngày..."
                                   Grid.ColumnSpan="2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                     Value="">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                     Value="{x:Null}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <!--  DataGrid  -->
                    <DataGrid x:Name="ConstructionStaffDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              EnableRowVirtualization="True"
                              FontFamily="Montserrat"
                              HorizontalScrollBarVisibility="Visible"
                              IsReadOnly="False"
                              ItemsSource="{Binding FilteredStaffList}"
                              SelectedItem="{Binding SelectedStaff, Mode=TwoWay}"
                              ScrollViewer.CanContentScroll="False"
                              SelectionMode="Extended"
                              Style="{StaticResource ModernDataGrid}"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="FontFamily"
                                        Value="Montserrat" />
                                <Setter Property="FontSize"
                                        Value="13" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            

                            <!--  Handler  -->
                            <DataGridTextColumn Width="250"
                                                Binding="{Binding FullName}"
                                                Header="Cán Bộ xử lý">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment"
                                                Value="Center" />
                                        <Setter Property="VerticalAlignment"
                                                Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Center" />
                                        <Setter Property="VerticalContentAlignment"
                                                Value="Center" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>

                            <!--  Actions  -->
                            <DataGridTemplateColumn Width="200"
                                                    Header="Thao tác">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center"
                                                    Orientation="Horizontal">
                                            <!--  Edit button  -->
                                            <Button Margin="2"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource ModernActionButton}">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:ImageAwesome Width="14"
                                                                     Height="14"
                                                                     Foreground="White"
                                                                     Icon="Edit" />
                                                </StackPanel>
                                            </Button>

                                            <!--  Delete button  -->
                                            <Button Margin="2"
                                                    Background="Red"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource ModernActionButton}">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:ImageAwesome Width="14"
                                                                     Height="14"
                                                                     Foreground="White"
                                                                     Icon="Trash" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!--Pagination datagrid-->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="10">
                        <!-- Go first page -->
                        <Button Command="{Binding GoToFirstPageCommand}"
                                Style="{StaticResource PagingButtonStyle}">
                            <fa:ImageAwesome Icon="StepBackward"
                                             Width="16"
                                             Height="16"
                                             Foreground="White" />
                        </Button>

                        <!-- Prev page -->
                        <Button Command="{Binding PreviousPageCommand}"
                                Style="{StaticResource PagingButtonStyle}">
                            <fa:ImageAwesome Icon="ChevronLeft"
                                             Width="16"
                                             Height="16"
                                             Foreground="White" />
                        </Button>

                        <!-- Show page number -->
                        <TextBlock Text="{Binding CurrentPage}"
                                   Margin="10,0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="14" />
                        <TextBlock Text="/"
                                   Margin="2,0"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                        <TextBlock Text="{Binding TotalPages}"
                                   Margin="2,0"
                                   VerticalAlignment="Center"
                                   FontSize="14" />

                        <!-- Next page -->
                        <Button Command="{Binding NextPageCommand}"
                                Style="{StaticResource PagingButtonStyle}">
                            <fa:ImageAwesome Icon="ChevronRight"
                                             Width="16"
                                             Height="16"
                                             Foreground="White" />
                        </Button>

                        <!-- Last page -->
                        <Button Command="{Binding GoToLastPageCommand}"
                                Style="{StaticResource PagingButtonStyle}">
                            <fa:ImageAwesome Icon="StepForward"
                                             Width="16"
                                             Height="16"
                                             Foreground="White" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
