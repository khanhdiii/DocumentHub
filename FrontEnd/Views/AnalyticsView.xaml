<UserControl x:Class="DocumentHub.FrontEnd.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

  <UserControl.Resources>
    <Color x:Key="PrimaryColor">#FF2B6BEA</Color>
    <Color x:Key="AccentColor">#FF00B894</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="MuterText">#FF6B7280</Color>
    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrush"
                     Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SurfaceBrush"
                     Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="MutedTextBrush"
                     Color="{StaticResource MuterText}" />

    <!-- Corner radius and spacing -->
    <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
    <Thickness x:Key="CardPadding">14</Thickness>

    <!-- Card header text style -->
    <Style TargetType="TextBlock"
           x:Key="CardHeader">
      <Setter Property="FontSize"
              Value="15" />
      <Setter Property="Margin"
              Value="20" />
      <Setter Property="FontWeight"
              Value="Bold" />
      <Setter Property="Foreground"
              Value="{StaticResource PrimaryBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Background="#FFF2F5FB"
        Margin="12">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <!-- Title -->
        <TextBlock Style="{StaticResource CardHeader}"
                   Text="Phân tích văn bản" />

        <!-- Total Docs -->
        <UniformGrid Rows="1"
                     Columns="3"
                     HorizontalAlignment="Center"
                     Margin="0,10,0,10">
          <!-- Incoming Docs -->
          <Border Width="150"
                  Height="100"
                  Background="#E8F5E9"
                  CornerRadius="8"
                  BorderBrush="Green"
                  BorderThickness="2"
                  Padding="10"
                  Margin="10">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
              <TextBlock Text="Tổng văn bản đến"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="Green"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding TotalIncoming}"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="DarkGreen"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Outgoing Docs -->
          <Border Width="150"
                  Height="100"
                  Background="#FFEBEE"
                  CornerRadius="8"
                  BorderBrush="Red"
                  BorderThickness="2"
                  Padding="10"
                  Margin="10">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
              <TextBlock Text="Tổng văn bản đi"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="Red"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding TotalOutgoing}"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="DarkRed"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Work progress -->
          <Border Width="150"
                  Height="100"
                  Background="#E3F2FD"
                  CornerRadius="8"
                  BorderBrush="Blue"
                  BorderThickness="2"
                  Padding="10"
                  Margin="10">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
              <TextBlock Text="Tổng tiến độ"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="Blue"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding TotalProgress}"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="DarkBlue"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </UniformGrid>

        <!-- ComboBox year -->
        <ComboBox ItemsSource="{Binding Years}"
                  SelectedItem="{Binding SelectedYear}"
                  HorizontalAlignment="Right"
                  Width="120"
                  Height="30"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Margin="0,17,30,0" />

        <!-- Chart -->
        <lvc:CartesianChart Series="{Binding Series}"
                            Height="400">
          <lvc:CartesianChart.AxisX>
            <lvc:Axis Labels="{Binding Labels}"
                      Foreground="DarkBlue"
                      FontSize="12" />
          </lvc:CartesianChart.AxisX>
          <lvc:CartesianChart.AxisY>
            <lvc:Axis Title="Số lượng / Tiến độ"
                      Foreground="DarkBlue"
                      FontSize="14" />
          </lvc:CartesianChart.AxisY>
        </lvc:CartesianChart>

        <!-- Title chart -->
        <TextBlock Text="Bảng thống kê số lượng văn bản theo từng tháng"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#FF2B6BEA"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0" />

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
